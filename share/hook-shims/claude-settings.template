{
  "$comment": "clagentic-lite Claude Code hook wiring. Generated by `clagentic enroll`. Do not edit by hand — re-run `clagentic enroll --force` to regenerate. managed-by: clagentic",
  "hooks": {
    "SessionStart": [
      { "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/session-start.sh" }
    ],
    "UserPromptSubmit": [
      { "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/prompt-inject.sh" }
    ],
    "PreToolUse": [
      { "matcher": "Bash",       "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/pre-bash-guard.sh" },
      { "matcher": "Write|Edit", "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/pre-write-guard.sh" }
    ],
    "Stop": [
      { "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/stop-summarize.sh" }
    ]
  },
  "permissions": {
    "$comment": "Repository-scope only. No personal infrastructure.",
    "allow": [
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(sqlite3 .clagentic/*)",
      "Bash(scripts/*)",
      "Bash(gitleaks:*)",
      "Bash(semgrep:*)",
      "Bash(osv-scanner:*)"
    ]
  }
}
