{
  "$comment": "clagentic-lite Claude Code hook wiring · clagentic-settings-version: v4 · managed-by: clagentic. Do not edit by hand — re-run `clagentic-lite enroll --force` or `clagentic-lite update` to regenerate.",
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/session-start.sh" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/prompt-inject.sh" }] }
    ],
    "PreToolUse": [
      { "matcher": "Bash",       "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/pre-bash-guard.sh" }] },
      { "matcher": "Write|Edit", "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/pre-write-guard.sh" }] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/post-tool-nudge.sh" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "__CLAGENTIC_HOME__/.claude/hooks/stop-summarize.sh" }] }
    ]
  },
  "permissions": {
    "$comment": "Repository-scope only. No personal infrastructure.",
    "allow": [
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(sqlite3 .clagentic/lite/*)",
      "Bash(scripts/*)",
      "Bash(gitleaks:*)",
      "Bash(semgrep:*)",
      "Bash(osv-scanner:*)"
    ]
  }
}
