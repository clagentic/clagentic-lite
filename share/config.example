# clagentic-lite — global config template.
# Written to ~/.config/clagentic/config by `clagentic-lite init`.
# Per-repo .clagentic/config is OPTIONAL and SPARSE — only override keys.
# Load order at gate-run time: global config → per-repo .clagentic/config → env vars.
#
# Per-role contract: each role has its own primary CLI+model and an ordered
# fallback chain. The chain is walked left-to-right when the primary fails
# (non-zero exit, parse failure, timeout). Each entry is "cmd:tier" where
# tier resolves to a concrete model via the CLAGENTIC_MODEL_* table below.
#
# Roles are independent. Codex does not implicitly fall back to Claude (or
# vice versa) — every fallback step is something you wrote down on purpose.

# ---------- tool home ----------
# Set automatically by `clagentic-lite init`. Edit only if you move the install.
# CLAGENTIC_HOME is the deprecated name — still honored with a one-time warning for
# back-compat. Migrate to CLAGENTIC_LITE_HOME.
CLAGENTIC_LITE_HOME=

# ---------- model tier table ----------
# Resolve symbolic tier names to concrete model strings for each CLI.
# This is the only place model version literals live. Agent files and the
# wrapper script reference tier names only.
#
# Format: CLAGENTIC_MODEL_<CLI>_<TIER>=<model-id-for-that-cli>
# Tiers (suggested): flagship, default, cheap
#
# Claude tiers
CLAGENTIC_MODEL_CLAUDE_FLAGSHIP=opus
CLAGENTIC_MODEL_CLAUDE_DEFAULT=sonnet
CLAGENTIC_MODEL_CLAUDE_CHEAP=haiku
#
# Codex tiers — by default, intentionally left blank so codex uses whatever
# model is configured in ~/.codex/models.json (the live runtime tier map).
# That file is the canonical source; clagentic-lite reads it automatically via
# resolve_step. Do not hardcode model version strings here — they rot silently
# when OpenAI renames models. Update ~/.codex/models.json instead.
#
# Tier name alignment: ~/.codex/models.json uses "flagship", "mini", "spark".
# clagentic-lite resolves "default" → default_tier in models.json, and looks
# up "mini"/"spark" directly. Env vars win if set, so you can override a
# specific tier without touching models.json:
# CLAGENTIC_MODEL_CODEX_FLAGSHIP=<specific-model-id>
# CLAGENTIC_MODEL_CODEX_MINI=<specific-model-id>
# CLAGENTIC_MODEL_CODEX_SPARK=<specific-model-id>
# CLAGENTIC_MODEL_CODEX_CHEAP=<same-as-spark, for legacy :cheap chains>
#
# Add more CLI tables here if you point a role at a different CLI.
# Example for a local ollama-backed entry:
# CLAGENTIC_MODEL_OLLAMA_DEFAULT=llama3.1:8b

# ---------- roles ----------
# Each role: PRIMARY (cmd + tier) and CHAIN (comma-separated cmd:tier list).
# Empty CHAIN means "no fallback — fail to degraded envelope on primary failure".

# Builder = primary author. Most edits go through this.
CLAGENTIC_BUILDER_CMD=claude
CLAGENTIC_BUILDER_TIER=default
CLAGENTIC_BUILDER_CHAIN=codex:default,claude:flagship

# Reviewer = cross-vendor reviewer. A different CLI from Builder is recommended;
# `clagentic-lite init` warns when they match.
# Tier names in chains: use flagship/mini/spark for codex (matching models.json),
# or flagship/default/cheap for claude. Both work; models.json names are canonical
# for codex since that file is the live source of model strings.
CLAGENTIC_REVIEWER_CMD=codex
CLAGENTIC_REVIEWER_TIER=flagship
CLAGENTIC_REVIEWER_CHAIN=claude:default,codex:flagship

# Auditor = LLM narration on top of deterministic scans (gitleaks/semgrep/osv).
# The Auditor never gates. Local tools own the security path.
CLAGENTIC_AUDITOR_CMD=codex
CLAGENTIC_AUDITOR_TIER=flagship
CLAGENTIC_AUDITOR_CHAIN=claude:default

# Merge-gate = final pre-merge sanity check. Reads all green-gate output,
# either approves or refuses. Never opens a PR, never pushes.
CLAGENTIC_GATE_CMD=claude
CLAGENTIC_GATE_TIER=default
CLAGENTIC_GATE_CHAIN=codex:flagship

# Summarizer = cheap model used for per-turn Stop-hook summaries.
# Uses :spark (codex) / :cheap (claude) — the lightest available tier.
CLAGENTIC_SUMMARIZER_CMD=claude
CLAGENTIC_SUMMARIZER_TIER=cheap
CLAGENTIC_SUMMARIZER_CHAIN=codex:spark

# ---------- role enforcement ----------
# By default, when every step in a role's chain fails, the wrapper emits a
# "degraded" envelope (parseable output, non-blocking) and the gate continues.
# Set CLAGENTIC_<ROLE>_REQUIRED=1 to make full-chain failure a hard error
# (non-zero exit, gate blocks). Use this when the cross-vendor property is
# non-negotiable: e.g. setting CLAGENTIC_REVIEWER_REQUIRED=1 ensures a
# same-vendor fallback is a detectable gate failure rather than a silent
# degradation. ROLE names: BUILDER, REVIEWER, AUDITOR, GATE, SUMMARIZER.
# CLAGENTIC_REVIEWER_REQUIRED=0
# CLAGENTIC_AUDITOR_REQUIRED=0
# CLAGENTIC_GATE_REQUIRED=0

# ---------- gates ----------
# Comma-separated list of gates to run on /ship. Omit to run all.
# Available: secrets,deps,sast,review,adversarial,merge-gate
CLAGENTIC_GATES=secrets,deps,sast,review,adversarial,merge-gate

# Severity threshold for blocking on /review findings.
# Values: low | medium | high | critical
CLAGENTIC_BLOCK_SEVERITY=high

# Space-separated directory paths to exclude from osv-scanner (v2.x only, passed as
# --experimental-exclude per entry). Use for demo fixtures, vendored examples, or dirs
# that are not deployed. Paths are relative to the repo root.
# CLAGENTIC_OSV_EXCLUDE=examples vendor

# osv-scanner severity threshold. Only vulnerabilities at this level or above block the gate.
# Options: CRITICAL, HIGH, MEDIUM, LOW. Default: CRITICAL. Newer osv-scanner
# releases expose severity in JSON; clagentic-lite applies this threshold locally.
# Set to LOW to restore the original block-on-any-finding behavior.
CLAGENTIC_OSV_SEVERITY=CRITICAL

# Stop-hook debounce: only summarize after N seconds of quiet.
CLAGENTIC_SUMMARIZE_DEBOUNCE_SEC=20

# Disable memory recall injection entirely (UserPromptSubmit hook).
CLAGENTIC_DISABLE_RECALL=0

# Disable FTS5 full-text search for recall and force the LIKE fallback.
# Set =1 on platforms where SQLite was compiled without FTS5 (rare; most SQLite
# builds since 2015 include it), or if you prefer the simpler LIKE behavior.
# When unset or 0, recall uses FTS5 MATCH for filtering if turns_fts exists,
# falling back to LIKE silently when FTS5 is unavailable.
# CLAGENTIC_DISABLE_FTS=0

# Disable on-disk handoff frame: Stop hook will not write .clagentic/lite/handoff.md
# and SessionStart hook will not inject it. Set =1 if you prefer auto-compact only,
# or if the handoff file is causing noise in your workflow.
CLAGENTIC_DISABLE_HANDOFF=0

# Minimum keyword count required to trigger recall injection (UserPromptSubmit hook).
# If fewer than this many keywords survive prompt extraction (after stopword filtering
# and dedup), injection is skipped entirely for that turn. Gating is on the count of
# the user's own prompt tokens — not on any corpus-derived score — so the SQL query,
# result set, and ORDER BY are unchanged when the gate allows injection.
# Raise to suppress noisy injection on short or low-signal prompts (e.g. "ok", "yes").
# CLAGENTIC_RECALL_MIN_KEYWORDS=2

# Suppress the session-start update alert (set =1 if you manage updates manually
# or the network fetch is unwanted — e.g. air-gapped environments).
CLAGENTIC_SKIP_UPDATE_ALERT=0

# Context-budget monitor (PostToolUse hook).
# Estimates token cost of each tool result (4 bytes ≈ 1 token) and warns via
# additionalContext when a single result or the cumulative session total crosses
# the configured threshold. Totals are persisted in audit.db (context_budget table).
# Set CLAGENTIC_DISABLE_BUDGET=1 to opt out entirely.
# CLAGENTIC_DISABLE_BUDGET=0
# CLAGENTIC_RESULT_TOKEN_WARN=8000    # warn if a single tool result exceeds ~N tokens (default 8000, ~32 KB)
# CLAGENTIC_SESSION_TOKEN_WARN=50000  # warn if cumulative session tool output exceeds ~N tokens (default 50000, ~200 KB)

# Auto-summarize large tool results (PostToolUse hook).
# When a tool result exceeds the byte threshold, pipes it through the Summarizer
# role (llm-client.sh) and stores a digest in memory.db. Emits the first 100
# chars of the digest as additionalContext so the session sees a summary hint.
# The LLM call is best-effort with a 10-second timeout; any failure is silent.
# Set CLAGENTIC_DISABLE_AUTOSUMMARIZE=1 to opt out entirely.
# CLAGENTIC_AUTOSUMMARIZE_BYTES=32768  # auto-summarize tool results larger than N bytes (default 32768 = 32KB)
# CLAGENTIC_DISABLE_AUTOSUMMARIZE=0    # set to 1 to disable auto-summarize

# Memory recall row limit: max turns returned by recall (default 5).
# CLAGENTIC_RECALL_LIMIT=5

# Memory recall char budget: total chars injected per recall call (default 1500).
# Whole rows are dropped when the budget would be exceeded — no mid-row splits.
# CLAGENTIC_RECALL_MAX_CHARS=1500

# Memory row cap: oldest rows beyond this limit are pruned after each INSERT (default 5000).
# Housekeeping is opportunistic and silent — no scheduler, no daemon, one DELETE.
# CLAGENTIC_MEMORY_MAX_ROWS=5000

# Per-LLM-call timeout (seconds). Hung CLI → step failure → chain advances.
CLAGENTIC_LLM_TIMEOUT_SEC=180

# Input-size-proportional timeout scaling. When CLAGENTIC_LLM_TIMEOUT_AUTO_SCALE=1
# (the default), the per-call timeout is computed as:
#   timeout = BASE + ceil(input_bytes / BYTES_PER_SEC), capped at MAX_SEC.
# This prevents 180s from firing on very large diffs (200 KB+) while keeping
# short calls at the base timeout. Set AUTO_SCALE=0 to disable and use BASE only.
# BYTES_PER_SEC is ~300 B/s conservatively calibrated for large review diffs:
# a 156KB diff produces ceil(156251/300)=521s budget beyond the 180s base (701s total,
# well within MAX). The old default (500) timed out on that diff at 493s.
CLAGENTIC_LLM_TIMEOUT_MAX_SEC=1800
CLAGENTIC_LLM_TIMEOUT_BYTES_PER_SEC=300
CLAGENTIC_LLM_TIMEOUT_AUTO_SCALE=1
# Per-role overrides (optional — takes precedence over the global BASE/MAX):
# CLAGENTIC_REVIEWER_TIMEOUT_SEC=240
# CLAGENTIC_REVIEWER_TIMEOUT_MAX_SEC=1800  # per-role override; global max is now 1800

# Claude invocation surface: by default the wrapper does NOT pass --bare,
# because --bare disables OAuth/keychain reads and requires ANTHROPIC_API_KEY.
# Set =1 only if you authenticate Claude via API key — the --bare invocation
# is slightly tighter (skips hooks/auto-memory) but unusable on OAuth setups.
CLAGENTIC_CLAUDE_BARE=0

# Merge Gate: blocking by default. Set to 0 to make it advisory (the gate
# still runs and logs, but a 'refuse' decision won't stop /ship).
CLAGENTIC_MERGE_GATE_BLOCKING=1

# Fail-closed overrides for missing deterministic security tools. The default
# is to BLOCK if the tool isn't installed (the gate can't run, so it can't
# pass). Set =1 only when you've deliberately chosen to run without it.
CLAGENTIC_ALLOW_MISSING_GITLEAKS=0
CLAGENTIC_ALLOW_MISSING_OSV=0
CLAGENTIC_ALLOW_MISSING_SEMGREP=0

# Strict preflight: make `clagentic-lite init` exit non-zero if any required
# tool is missing. Off by default so scripted init runs don't fail spuriously.
CLAGENTIC_STRICT_PREFLIGHT=0

# ---------- repo host ----------
# github | gitlab | gitea | none
CLAGENTIC_REPO_HOST=github

# Default branch (assumed protected — writes blocked by pre-write-guard).
CLAGENTIC_DEFAULT_BRANCH=main

# ---------- security gate bypass controls ----------
# These vars let you work around pre-existing issues without modifying harness
# source code. Use config, not code edits. See docs/GATES.md for context.

# Comma-separated bash-guard rule IDs to skip (e.g. R-005,R-011).
# Only use for rules that conflict with legitimate workflows in your project.
# Unset means no rules are skipped.
# CLAGENTIC_ALLOW_BASH_RULES=

# Allow writes to the default branch (disables W-001 in pre-write-guard).
# Only set this if you are intentionally working directly on the default branch.
# CLAGENTIC_ALLOW_DEFAULT_BRANCH_WRITE=1

# Skip the staleness check on gate output files (last-review.json,
# last-adversarial.md). Use when artifacts were produced in a prior CI step
# or an air-gapped environment where the files are known-fresh despite a
# HEAD SHA mismatch (e.g. the gate ran on the same diff in a different
# working tree). Without this flag, build_gate_summary refuses to feed a
# stale payload to the merge-gate LLM.
# CLAGENTIC_ALLOW_STALE_PAYLOAD=1

# ---------- reviewer-consulted deferrals ----------
# File: .clagentic/deferrals.json in the enrolled repo (gitignored — already
# under .clagentic/ which gates.sh gitignores, so no extra config needed).
#
# When present, the file is injected verbatim into the reviewer system prompt
# before the diff is reviewed. The LLM uses its judgment to decide whether
# each deferral still applies — suppression happens inside model reasoning,
# not in gate code. The gate does NOT post-filter findings based on this file.
#
# Fail-open: if the file is absent, empty, or unreadable, the review proceeds
# as if no deferrals exist. The gate never blocks on a missing deferrals file.
#
# Schema (JSON array):
# [
#   {
#     "id": "def-001",              # stable identifier (required)
#     "category": "sql",            # finding category this applies to (optional)
#     "file": "scripts/seed.sh",   # exact path or path glob (optional)
#     "description": "...",         # human-readable reason (required)
#     "expires": "2026-12-31",      # ISO date — LLM reasons about expiry; gate does not parse (optional)
#     "acknowledged_by": "you"      # who approved the deferral (optional)
#   }
# ]
#
# The `expires` field is passed verbatim to the LLM. The gate does not compute
# or enforce expiry dates — the LLM reasons about whether the deferral is still
# valid given its expiry and the diff under review.
#
# Deferrals vs. accepted-risks.md:
#   accepted-risks.md  — architectural risk decisions; read by the merge-gate
#                        (Gate 6); deterministic gate plumbing post-filters.
#   deferrals.json     — operator guidance injected into the reviewer prompt
#                        (Gate 3); suppression is inside LLM judgment, not code.
# No new env var is needed — the feature is always active when the file exists.

# ---------- cross-round finding dedup ----------
# Default-on: suppress findings already reported in a prior review round when the
# relevant diff lines are unchanged since. Key strategy is content-hash (sha256
# of a 5-line context window), so the key survives line shifts. Default: on (1).
# Seen-keys are persisted in .clagentic/lite/review-seen-keys (gitignored).
# Reset with: clagentic-lite gates review --reset-dedup
# Set =0 to opt out and see all findings on every round.
# CLAGENTIC_CROSS_ROUND_DEDUP=1

# ---------- adversarial invariant-feed ----------
# File: .clagentic/lite/invariants.json in the enrolled repo (gitignored —
# already under .clagentic/lite/, same convention as last-review.json,
# review-seen-keys, and audit.db).
#
# When present AND CLAGENTIC_ADVERSARIAL_INVARIANTS=1, the file is injected
# verbatim into the adversarial (Auditor) system prompt before the diff is
# analyzed, with an instruction to verify the diff against each invariant —
# the inverse of the reviewer deferrals injection above ("must still hold and
# be re-checked" instead of "already reviewed, do not re-report"). This gives
# the adversarial pass forward-invariant memory across rounds: findings
# resolved in an earlier round become invariants the Auditor actively checks
# for reintroduction, including at a wider scope than where they were
# originally fixed.
#
# Opt-in default: off (0). Set =1 to enable.
# CLAGENTIC_ADVERSARIAL_INVARIANTS=0
#
# Fail-open: if the file is absent, empty, or unreadable, the adversarial
# pass proceeds as if no invariants exist. The gate never blocks on a missing
# invariants file — the adversarial pass is non-blocking by design regardless.
#
# Schema (JSON array):
# [
#   {
#     "id": "inv-001",                    # stable identifier (required)
#     "category": "security",             # finding category (optional)
#     "file": "scripts/example.sh",       # exact path or path glob (optional)
#     "statement": "..."                  # the invariant to verify (required)
#   }
# ]
#
# Population is automatic (lr-63359e). When a finding resolves -- present in
# one round's findings, absent from the next round's on the same content-hash
# key the review/adversarial cross-round dedup machinery already tracks --
# the writer distills its message+category into an invariant line and appends
# it to the file. Dedupes on (file, statement) at append time and caps total
# entries at CLAGENTIC_INVARIANT_FEED_MAX (default 200, oldest dropped first)
# so the feed's own storage cannot grow unboundedly. See docs/GATES.md
# "Invariant-feed writer" for the full resolve-signal mechanics.
# CLAGENTIC_INVARIANT_FEED_MAX=200

# Per-field length cap (chars) applied at the write boundary, before a
# category/file/statement field is written to invariants.json (lr-cda4b9).
# All three fields trace back to adversarial/review LLM finding text, so this
# guards against a single planted finding ballooning invariants.json or the
# prompt it is later re-injected into. Truncates rather than drops the entry.
# CLAGENTIC_INVARIANT_FEED_MAX_FIELD_CHARS=500

# ---------- chunked review ----------
# Opt-in diff chunking for the review gate. When enabled (=1) and the diff
# exceeds the threshold, the diff is split into chunks and reviewed per-chunk.
# Per-chunk audit rows use gate='review-chunk'. A merged envelope is assembled
# from all chunks and stamped as the final last-review.json output.
# Warning: N chunks = N LLM calls. For large diffs this can be costly.
# Opt-in default: off (0). Enable when single-pass review times out on very
# large diffs where per-chunk context is sufficient.
# CLAGENTIC_REVIEW_CHUNKING=1

# Chunking threshold in bytes. When CLAGENTIC_REVIEW_CHUNKING=1 and the diff
# is larger than this value, the chunking path is taken. Default: 262144 (256 KB).
# CLAGENTIC_REVIEW_CHUNK_BYTES=262144

# Operator-facing alias for the chunking threshold (in KB, not bytes).
# When set, overrides CLAGENTIC_REVIEW_CHUNK_BYTES. Use whichever unit is more
# natural for your workflow.
# CLAGENTIC_REVIEWER_MAX_DIFF_KB=256

# ---------- smoke test ----------
# CLAGENTIC_SMOKE_NO_LLM=1
# When set, smoke.sh skips live LLM calls and substitutes a stub JSON envelope.
# Use for in-session smoke runs or CI environments without LLM access.
# Default: unset (live LLM calls enabled).
