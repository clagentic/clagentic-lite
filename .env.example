# clagentic-lite — copy to .env and fill in. .env is gitignored.
#
# Per-role contract: each role has its own primary CLI+model and an ordered
# fallback chain. The chain is walked left-to-right when the primary fails
# (non-zero exit, parse failure, timeout). Each entry is "cmd:tier" where
# tier resolves to a concrete model via the CLAGENTIC_MODEL_* table below.
#
# Roles are independent. Codex does not implicitly fall back to Claude (or
# vice versa) — every fallback step is something you wrote down on purpose.

# ---------- identity ----------
# Org slug used in commit trailers and log lines.
CLAGENTIC_ORG=

# Project slug. Defaults to the repo dir name if unset.
CLAGENTIC_PROJECT=

# ---------- model tier table ----------
# Resolve symbolic tier names to concrete model strings for each CLI.
# This is the only place model version literals live. Agent files and the
# wrapper script reference tier names only.
#
# Format: CLAGENTIC_MODEL_<CLI>_<TIER>=<model-id-for-that-cli>
# Tiers (suggested): flagship, default, cheap
#
# Claude tiers
CLAGENTIC_MODEL_CLAUDE_FLAGSHIP=opus
CLAGENTIC_MODEL_CLAUDE_DEFAULT=sonnet
CLAGENTIC_MODEL_CLAUDE_CHEAP=haiku
#
# Codex tiers — defaults assume a ChatGPT account (Plus/Pro/Free).
# API-key accounts can also use gpt-5-codex / gpt-5.5-codex / etc.;
# ChatGPT-account users CANNOT — those return HTTP 400.
CLAGENTIC_MODEL_CODEX_FLAGSHIP=gpt-5.5
CLAGENTIC_MODEL_CODEX_DEFAULT=gpt-5.5
CLAGENTIC_MODEL_CODEX_CHEAP=gpt-5.5-mini
#
# Add more CLI tables here if you point a role at a different CLI.
# Example for a local ollama-backed entry:
# CLAGENTIC_MODEL_OLLAMA_DEFAULT=llama3.1:8b

# ---------- roles ----------
# Each role: PRIMARY (cmd + tier) and CHAIN (comma-separated cmd:tier list).
# Empty CHAIN means "no fallback — fail to degraded envelope on primary failure".

# Builder = primary author. Most edits go through this.
CLAGENTIC_BUILDER_CMD=claude
CLAGENTIC_BUILDER_TIER=default
CLAGENTIC_BUILDER_CHAIN=codex:default,claude:flagship

# Reviewer = cross-vendor reviewer. A different CLI from Builder is recommended;
# install.sh --check warns when they match.
CLAGENTIC_REVIEWER_CMD=codex
CLAGENTIC_REVIEWER_TIER=default
CLAGENTIC_REVIEWER_CHAIN=claude:default,codex:flagship

# Auditor = LLM narration on top of deterministic scans (gitleaks/semgrep/osv).
# The Auditor never gates. Local tools own the security path.
CLAGENTIC_AUDITOR_CMD=codex
CLAGENTIC_AUDITOR_TIER=default
CLAGENTIC_AUDITOR_CHAIN=claude:default

# Merge-gate = final pre-merge sanity check. Reads all green-gate output,
# either approves or refuses. Never opens a PR, never pushes.
CLAGENTIC_GATE_CMD=claude
CLAGENTIC_GATE_TIER=default
CLAGENTIC_GATE_CHAIN=codex:default

# Summarizer = cheap model used for per-turn Stop-hook summaries.
CLAGENTIC_SUMMARIZER_CMD=claude
CLAGENTIC_SUMMARIZER_TIER=cheap
CLAGENTIC_SUMMARIZER_CHAIN=codex:cheap

# ---------- gates ----------
# Comma-separated list of gates to run on /ship. Omit to run all.
# Available: secrets,deps,sast,review,adversarial,merge-gate
CLAGENTIC_GATES=secrets,deps,sast,review,adversarial,merge-gate

# Severity threshold for blocking on /review findings.
# Values: low | medium | high | critical
CLAGENTIC_BLOCK_SEVERITY=high

# Stop-hook debounce: only summarize after N seconds of quiet.
CLAGENTIC_SUMMARIZE_DEBOUNCE_SEC=20

# Disable memory recall injection entirely (UserPromptSubmit hook).
CLAGENTIC_DISABLE_RECALL=0

# Per-LLM-call timeout (seconds). Hung CLI → step failure → chain advances.
CLAGENTIC_LLM_TIMEOUT_SEC=180

# Claude invocation surface: by default the wrapper does NOT pass --bare,
# because --bare disables OAuth/keychain reads and requires ANTHROPIC_API_KEY.
# Set =1 only if you authenticate Claude via API key — the --bare invocation
# is slightly tighter (skips hooks/auto-memory) but unusable on OAuth setups.
CLAGENTIC_CLAUDE_BARE=0

# Merge Gate: blocking by default. Set to 0 to make it advisory (the gate
# still runs and logs, but a 'refuse' decision won't stop /ship).
CLAGENTIC_MERGE_GATE_BLOCKING=1

# Fail-closed overrides for missing deterministic security tools. The default
# is to BLOCK if the tool isn't installed (the gate can't run, so it can't
# pass). Set =1 only when you've deliberately chosen to run without it.
CLAGENTIC_ALLOW_MISSING_GITLEAKS=0
CLAGENTIC_ALLOW_MISSING_OSV=0
CLAGENTIC_ALLOW_MISSING_SEMGREP=0

# Strict preflight: make install.sh --check exit non-zero if any required
# tool is missing. Off by default so CI re-checks don't fail spuriously.
CLAGENTIC_STRICT_PREFLIGHT=0

# ---------- repo host ----------
# github | gitlab | gitea | none
CLAGENTIC_REPO_HOST=github

# Default branch (assumed protected — writes blocked by pre-write-guard).
CLAGENTIC_DEFAULT_BRANCH=main
