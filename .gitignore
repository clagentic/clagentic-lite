# clagentic-lite local state
# NOTE: .clagentic/* (not .clagentic/) so git still descends into the
# directory to evaluate the loadout carve-out below -- a trailing-slash
# .clagentic/ pattern excludes the directory from traversal entirely and
# negation patterns for paths inside it are never evaluated.
.clagentic/*
# loadout enrollment config is tracked repo config, not local runtime state
!.clagentic/loadout
!.clagentic/loadout/config.yaml
.env
.env.local

# editor
.vscode/
.idea/
*.swp
.DS_Store

# language ecosystems (example projects)
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
build/
*.log

# LORE local state (we use lore during dev but don't ship it)
.lore
