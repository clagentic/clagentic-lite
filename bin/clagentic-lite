#!/bin/sh
# clagentic-lite :: CLI entry point
# Clone once to $CLAGENTIC_HOME. Use this CLI for all lifecycle operations.
#
# Subcommands:
#   init [--reconfigure]          first-time setup: prereqs, global config, symlink
#   enroll [--self] [--force] [PATH...]   wire hooks + init DBs for a repo
#   unenroll [--purge] [PATH]             remove clagentic hooks, deregister
#   list                                  show enrolled repos + status
#   doctor                                diagnostics punch list
#   update [--restamp]                    git pull + re-prereq + re-stamp shims
#   recall [keywords...]                  search session memory for matching summaries
#   remember "<note>" [tags]              store a manual memory entry
#
# Design: tool is cloned once (default: ~/.clagentic-lite, override via
# $CLAGENTIC_HOME). Per-repo enrollment writes .clagentic/{audit,memory}.db,
# thin shims in .git/hooks/ that call back to $CLAGENTIC_HOME/scripts/, and
# .claude/settings.json + symlinks to .claude/{commands,agents} so Claude Code
# picks up hook wiring and slash commands in the enrolled project.
# The tool repo itself is never the thing under gates by default.

set -e

# Resolve CLAGENTIC_HOME: env var wins, else default.
: "${CLAGENTIC_HOME:=$HOME/.clagentic-lite}"
export CLAGENTIC_HOME

# Source platform shims from our own install tree.
SCRIPTS_DIR="$CLAGENTIC_HOME/scripts"
if [ ! -f "$SCRIPTS_DIR/platform.sh" ]; then
  # Bootstrap path: being invoked before init has verified $CLAGENTIC_HOME.
  # Try to resolve from this script's own location.
  _SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
  SCRIPTS_DIR="$(dirname "$_SELF_DIR")/scripts"
fi
if [ ! -f "$SCRIPTS_DIR/platform.sh" ]; then
  printf 'clagentic-lite: cannot find scripts/platform.sh in %s\n' "$CLAGENTIC_HOME" >&2
  printf 'Set CLAGENTIC_HOME to the clagentic-lite checkout directory.\n' >&2
  exit 1
fi
. "$SCRIPTS_DIR/platform.sh"

SHARE_DIR="$CLAGENTIC_HOME/share"
REGISTRY="$HOME/.local/state/clagentic/registry"
GLOBAL_CONFIG="$HOME/.config/clagentic/config"
LOCAL_BIN="$HOME/.local/bin"
CLI_SYMLINK="$LOCAL_BIN/clagentic-lite"

# Shim template version marker. Bump this string when the template content
# changes so `clagentic-lite update` knows to re-stamp enrolled repos.
SHIM_VERSION="v1"

# Claude Code artifact version markers. Bump when the corresponding template
# changes so `clagentic-lite update` re-stamps enrolled repos automatically.
CLAUDE_SETTINGS_VERSION="v3"
CLAUDE_MD_VERSION="v3"

# Single source of truth for the security-gate tool list. Adding a new
# scanner means editing this one line — _run_prereq_checks (init/update)
# and cmd_doctor both iterate this list, so they stay in sync.
# Space-separated POSIX-sh string (no arrays).
CLAGENTIC_SECURITY_TOOLS="gitleaks semgrep osv-scanner"

say()  { printf '[clagentic-lite] %s\n' "$*"; }
warn() { printf '[clagentic-lite] WARN: %s\n' "$*" 1>&2; }
die()  { printf '[clagentic-lite] ERROR: %s\n' "$*" 1>&2; exit 1; }

# ---------------------------------------------------------------- helpers

# Portable absolute path resolution (no readlink -f on macOS by default).
ds_realpath() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1" 2>/dev/null || printf '%s' "$1"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null
  else
    # POSIX fallback: cd to dir, print pwd + basename.
    _rp_dir="$(dirname "$1")"
    _rp_base="$(basename "$1")"
    (cd "$_rp_dir" 2>/dev/null && printf '%s/%s' "$(pwd)" "$_rp_base") || printf '%s' "$1"
  fi
}

# Read the version marker from an installed hook shim.
shim_version() {
  _sv_file="$1"
  [ -f "$_sv_file" ] || { printf ''; return; }
  awk '/clagentic-lite hook shim/ { print; exit }' "$_sv_file" 2>/dev/null | sed 's/.*· \(v[^ ]*\) ·.*/\1/'
}

# Read the version marker from an installed .claude/settings.json.
# Looks for "clagentic-settings-version: vN" in the $comment field.
claude_settings_version() {
  _csv_file="$1"
  [ -f "$_csv_file" ] || { printf ''; return; }
  grep -o 'clagentic-settings-version: v[^ ·"]*' "$_csv_file" 2>/dev/null | sed 's/clagentic-settings-version: //'
}

# Read the version marker from an installed CLAUDE.md.
# Looks for "clagentic-claude-md-version: vN" in the managed-by comment.
claude_md_version() {
  _cmv_file="$1"
  [ -f "$_cmv_file" ] || { printf ''; return; }
  grep -o 'clagentic-claude-md-version: v[^ ·>]*' "$_cmv_file" 2>/dev/null | sed 's/clagentic-claude-md-version: //'
}

# Stamp a hook shim from share/hook-shims/<name>.template into a repo's
# .git/hooks/<name>. Substitutes __CLAGENTIC_HOME__ with the actual path.
# Args: TEMPLATE_NAME HOOKS_DIR
# Returns: 0 stamped, 1 refused (existing non-clagentic hook, no --force)
stamp_shim() {
  _ss_name="$1"
  _ss_hooks_dir="$2"
  _ss_target="$_ss_hooks_dir/$_ss_name"
  _ss_template="$SHARE_DIR/hook-shims/${_ss_name}.template"
  [ -f "$_ss_template" ] || { warn "template missing: $_ss_template"; return 1; }

  # If the hook file exists and is NOT clagentic-owned, refuse unless --force.
  if [ -f "$_ss_target" ]; then
    if grep -q 'managed-by: clagentic' "$_ss_target" 2>/dev/null; then
      : # clagentic-owned — overwrite silently
    elif [ "${ENROLL_FORCE:-0}" = "1" ]; then
      warn "overwriting existing non-clagentic hook at $_ss_target (--force)"
    else
      warn "existing hook at $_ss_target is not clagentic-managed — skipping (use --force to overwrite)"
      return 1
    fi
  fi

  # Write shim: substitute __CLAGENTIC_HOME__ with the real path.
  sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_ss_template" > "$_ss_target"
  chmod +x "$_ss_target"
  return 0
}

# Stamp a wrapper-flavored CLAUDE.md into a non-git wrapper directory.
# Args: WRAPPER_DIR  ENROLLED_REPOS (space-separated absolute paths)
# No hook wiring — hooks are git-repo-rooted and must not fire from wrapper CWD.
# Skips if a non-clagentic CLAUDE.md already exists (unless ENROLL_FORCE=1).
_stamp_wrapper_claude_md() {
  _wcd="$1"; _wcd_repos="$2"
  _wcd_template="$SHARE_DIR/hook-shims/CLAUDE.md.wrapper.template"
  [ -f "$_wcd_template" ] || { warn "CLAUDE.md.wrapper.template missing — skipping wrapper CLAUDE.md"; return 0; }

  _wcd_target="$_wcd/CLAUDE.md"
  if [ -f "$_wcd_target" ] && ! grep -q 'managed-by: clagentic' "$_wcd_target" 2>/dev/null; then
    if [ "${ENROLL_FORCE:-0}" = "1" ]; then
      warn "overwriting existing non-clagentic CLAUDE.md in wrapper $_wcd (--force)"
    else
      warn "existing CLAUDE.md in wrapper $_wcd is not clagentic-managed — skipping (use --force to overwrite)"
      return 0
    fi
  fi

  # Generate the file directly — multiline table substitution via sed is
  # fragile (newlines, special chars in paths). Read template line by line;
  # replace the token line with the generated table.
  {
    while IFS= read -r _tmpl_line; do
      case "$_tmpl_line" in
        *__WRAPPER_PROJECT_TABLE__*)
          printf '| Subfolder | Absolute path |\n'
          printf '|---|---|\n'
          for _wr in $_wcd_repos; do
            _rel="${_wr#$_wcd}"
            _rel="${_rel#/}"
            [ -z "$_rel" ] && _rel="$_wr"
            printf '| `%s` | `%s` |\n' "$_rel" "$_wr"
          done
          ;;
        *)
          printf '%s\n' "$_tmpl_line"
          ;;
      esac
    done < "$_wcd_template"
  } > "$_wcd_target"
  say "stamped wrapper CLAUDE.md: $_wcd_target"
}

# ---------------------------------------------------------------- prereq helpers
#
# Single source of truth for "what tools does clagentic-lite need". cmd_init,
# cmd_update, and cmd_doctor all call into here so adding a new required tool
# means editing one function, not three.
#
# Required tools: hard prereqs. Init/update will offer to install; doctor
# will fail if absent.
# Security tools: needed by the secrets/sast/deps gates. Skippable via the
# ALLOW_MISSING_* env vars; doctor reports them as WARN, not FAIL.
# JSON validator: jq OR python3 satisfies the requirement (hooks fall back
# to python3 when jq is absent). Handled separately because of the "either-or".

# Look up per-OS install hints for a security tool, keyed off CLAGENTIC_SECURITY_TOOLS.
# Echoes "LINUX_HINT|DARWIN_HINT" — caller splits on '|'. Returns 1 for unknown
# names (so adding a name to CLAGENTIC_SECURITY_TOOLS without adding a hint case
# here fails loudly instead of silently degrading).
# semgrep's linux hint is dynamic (PEP 668 picker); the others are static.
_security_tool_hints() {
  _STH_NAME="$1"
  case "$_STH_NAME" in
    gitleaks)
      printf '%s|%s' \
        "see https://github.com/gitleaks/gitleaks#installing" \
        "brew install gitleaks"
      ;;
    semgrep)
      printf '%s|%s' "$(_semgrep_hint_linux)" "brew install semgrep"
      ;;
    osv-scanner)
      printf '%s|%s' \
        "see https://google.github.io/osv-scanner/installation/" \
        "brew install osv-scanner"
      ;;
    *)
      return 1
      ;;
  esac
}

# Pick the right semgrep install hint for this host. PEP 668 (Debian 12+,
# Ubuntu 23.04+, modern WSL) refuses unmanaged pip installs against system
# Python — suggesting `pip install --user` there produces the
# "externally-managed-environment" error. Order of preference:
#   1. pipx present                       -> pipx install semgrep
#   2. no pipx, Python NOT PEP-668        -> python3 -m pip install --user semgrep
#   3. no pipx, Python IS PEP-668 managed -> apt install pipx (then re-run init)
#   4. no pipx, no python3                -> point at vendor docs
_semgrep_hint_linux() {
  if command -v pipx >/dev/null 2>&1; then
    printf '%s' "pipx install semgrep"
    return
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf '%s' "see https://semgrep.dev/docs/getting-started/"
    return
  fi
  set -- /usr/lib/python3*/EXTERNALLY-MANAGED /usr/lib/python3/EXTERNALLY-MANAGED
  for _f in "$@"; do
    if [ -e "$_f" ]; then
      printf '%s' "apt install pipx  # then re-run \`clagentic-lite init\` (PEP 668 — system python refuses pip --user)"
      return
    fi
  done
  printf '%s' "python3 -m pip install --user semgrep"
}

# _run_prereq_checks MODE
#   MODE = "init"   -> ds_offer_install for required + security tools.
#   MODE = "update" -> same (so post-update checks match init coverage).
# Sets DS_CHECK_MISSING (required tools only) and DS_PENDING_INSTALLS.
# Prints the collated still-to-install summary at the end.
_run_prereq_checks() {
  _RPC_MODE="${1:-init}"
  DS_CHECK_MISSING=0; export DS_CHECK_MISSING
  ds_pending_reset

  # Required: sqlite3, git.
  ds_offer_install sqlite3 "apt install sqlite3" "brew install sqlite" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))
  ds_offer_install git "apt install git" "xcode-select --install" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))

  # Required: jq OR python3. Either one satisfies.
  if command -v jq >/dev/null 2>&1; then
    printf '  %-15s found: %s\n' "jq" "$(command -v jq)"
  elif command -v python3 >/dev/null 2>&1; then
    printf '  %-15s found (python3 fallback): %s\n' "jq" "$(command -v python3)"
  else
    ds_offer_install jq "apt install jq" "brew install jq" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))
    warn "no JSON validator — PreToolUse hooks will fail closed until jq or python3 is installed"
  fi

  # Security gate tools — required unless ALLOW_MISSING_* opts in. Not counted
  # toward DS_CHECK_MISSING because the user might legitimately opt out.
  # List of names lives in CLAGENTIC_SECURITY_TOOLS (top of file); hints come
  # from _security_tool_hints, which fails loudly if a name lacks a case
  # (catches "added to list but forgot to add hints" drift).
  for _stool in $CLAGENTIC_SECURITY_TOOLS; do
    _sthints=$(_security_tool_hints "$_stool") || \
      die "internal: no install hint for security tool '$_stool' (update _security_tool_hints in bin/clagentic-lite)"
    _stl="${_sthints%%|*}"
    _std="${_sthints##*|}"
    ds_offer_install "$_stool" "$_stl" "$_std" || true
  done

  # Nice-to-have: timeout / gtimeout.
  if ! command -v timeout >/dev/null 2>&1 && ! command -v gtimeout >/dev/null 2>&1; then
    printf '  %-15s MISSING (optional) — install: %s\n' "timeout" \
      "brew install coreutils (macOS) | apt install coreutils (Linux)"
    warn "no timeout/gtimeout — LLM calls will run without per-call timeouts"
  fi

  # Single collated summary at the bottom of the run.
  ds_pending_summary

  if [ "$DS_CHECK_MISSING" -gt 0 ]; then
    case "$_RPC_MODE" in
      update)
        say "$DS_CHECK_MISSING required tool(s) still missing post-update — fix them before next gate run"
        ;;
      *)
        say "$DS_CHECK_MISSING required tool(s) still missing — fix them and re-run \`clagentic-lite init\`"
        ;;
    esac
    if [ "${CLAGENTIC_STRICT_PREFLIGHT:-0}" = "1" ]; then
      die "strict preflight: $DS_CHECK_MISSING required tool(s) missing"
    fi
  fi
}

# ---------------------------------------------------------------- init

cmd_init() {
  RECONFIGURE=0
  for _arg in "$@"; do
    case "$_arg" in --reconfigure) RECONFIGURE=1 ;; esac
  done

  say "clagentic-lite init"
  say "CLAGENTIC_HOME: $CLAGENTIC_HOME"

  # 1. Verify this is a clagentic-lite checkout.
  if [ ! -f "$CLAGENTIC_HOME/scripts/gates.sh" ]; then
    die "$CLAGENTIC_HOME does not look like a clagentic-lite checkout (scripts/gates.sh missing)"
  fi

  # 1.5. Freshness check. If CLAGENTIC_HOME is a git checkout and the local
  # branch is behind its upstream, nudge the user to run `clagentic-lite update`
  # before continuing — otherwise init runs against stale code (the silent
  # footgun that bit early users when PRs #3/#4/#5 landed and they kept
  # re-running init without pulling).
  # Skippable with CLAGENTIC_SKIP_FETCH=1 for offline use, and silently
  # tolerant of failure (no upstream, no network, not a worktree, etc.).
  if [ "${CLAGENTIC_SKIP_FETCH:-0}" != "1" ] \
      && git -C "$CLAGENTIC_HOME" rev-parse --git-dir >/dev/null 2>&1; then
    # Best-effort fetch; suppress output. Network failures are non-fatal.
    git -C "$CLAGENTIC_HOME" fetch --quiet 2>/dev/null || true
    _BRANCH=$(git -C "$CLAGENTIC_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    _UPSTREAM=$(git -C "$CLAGENTIC_HOME" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
    if [ -n "$_BRANCH" ] && [ -n "$_UPSTREAM" ]; then
      _BEHIND=$(git -C "$CLAGENTIC_HOME" rev-list --count "HEAD..$_UPSTREAM" 2>/dev/null || echo 0)
      if [ "$_BEHIND" -gt 0 ] 2>/dev/null; then
        warn "$CLAGENTIC_HOME is $_BEHIND commit(s) behind $_UPSTREAM — run \`clagentic-lite update\` to pick up the latest fixes before re-running init"
      fi
    fi
  fi

  # 2. Prereq detection — shared helper used by init / update / doctor.
  #    On a re-run with config already present, the prereq sweep still runs
  #    (always useful), but the two-question front door is skipped — silence
  #    when nothing will change.
  say "checking prerequisites..."
  _run_prereq_checks init

  # 3. Two-question front door. Skip entirely when global config already
  #    exists and --reconfigure was not passed — otherwise re-runs of init
  #    pointlessly ask "Accept all defaults? [Y/n]" every time.
  if [ -f "$GLOBAL_CONFIG" ] && [ "$RECONFIGURE" -eq 0 ]; then
    say "global config already exists at $GLOBAL_CONFIG (use --reconfigure to re-prompt)"
  else
    _write_global_config
  fi

  # 4. Ensure ~/.local/bin/ exists.
  _ensure_local_bin

  # 5. Symlink ~/.local/bin/clagentic-lite -> $CLAGENTIC_HOME/bin/clagentic-lite.
  _install_symlink

  say "init complete"
  if [ -f "$GLOBAL_CONFIG" ] && [ "$RECONFIGURE" -eq 0 ]; then
    say "(no config changes — re-ran prereq + symlink only)"
  fi
  say "next: cd into any repo you want gates on, then run \`clagentic-lite enroll\`"
}

_write_global_config() {
  # Q1: accept all defaults?
  ACCEPT_DEFAULTS="y"
  if [ -t 0 ]; then
    printf 'Accept all defaults? [Y/n]: '
    read -r _q1 || _q1=""
    [ -z "$_q1" ] && _q1="y"
    case "$_q1" in y|Y|yes|YES) ACCEPT_DEFAULTS="y" ;; *) ACCEPT_DEFAULTS="n" ;; esac
  fi

  # Q2: vendor mode (only asked when accepting defaults or in granular mode).
  VENDOR_MODE="2"
  if [ "$ACCEPT_DEFAULTS" = "y" ] && [ -t 0 ]; then
    printf 'Vendor mode?  [1] Claude only  [2] Claude + Codex (cross-vendor, default): '
    read -r _q2 || _q2=""
    [ -z "$_q2" ] && _q2="2"
    VENDOR_MODE="$_q2"
  fi

  # Start with the example as the base.
  _CONFIG_SRC="$SHARE_DIR/config.example"
  [ -f "$_CONFIG_SRC" ] || die "share/config.example missing — is \$CLAGENTIC_HOME correct?"

  # Prepare destination directory.
  _config_dir="$(dirname "$GLOBAL_CONFIG")"
  if [ ! -d "$_config_dir" ]; then
    mkdir -p "$_config_dir" && chmod 700 "$_config_dir" \
      || { warn "cannot create $_config_dir"; return 1; }
  fi

  cp "$_CONFIG_SRC" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  # Stamp CLAGENTIC_HOME.
  awk -v home="$CLAGENTIC_HOME" '
    /^CLAGENTIC_HOME=/ { print "CLAGENTIC_HOME=" home; next }
    { print }
  ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
  mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  # Apply vendor mode: if mode=1 (Claude only), set all roles to claude.
  if [ "$VENDOR_MODE" = "1" ]; then
    awk '
      /^CLAGENTIC_(REVIEWER|AUDITOR)_CMD=/ { sub(/=.*/, "=claude"); }
      /^CLAGENTIC_(REVIEWER|AUDITOR)_CHAIN=/ { sub(/=.*/, "=claude:default"); }
      { print }
    ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
    mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
    chmod 600 "$GLOBAL_CONFIG"
    warn "Builder and Reviewer both set to 'claude'. Cross-vendor review surfaces blind spots that same-vendor review shares."
  fi

  # Granular flow: max 6 prompts when user declined all-defaults.
  if [ "$ACCEPT_DEFAULTS" = "n" ] && [ -t 0 ]; then
    _granular_config_prompts
  fi

  say "wrote global config: $GLOBAL_CONFIG (chmod 600)"
}

_granular_config_prompts() {
  # 6 prompts max: vendor mode, default branch, repo host, block severity,
  # builder primary, reviewer primary.
  printf 'Vendor mode?  [1] Claude only  [2] Claude + Codex (cross-vendor, default): '
  read -r _vm || _vm=""; [ -z "$_vm" ] && _vm="2"

  printf 'Default branch [main]: '
  read -r _db || _db=""; [ -z "$_db" ] && _db="main"

  printf 'Repo host (github|gitlab|gitea|none) [github]: '
  read -r _rh || _rh=""; [ -z "$_rh" ] && _rh="github"

  printf 'Block severity (low|medium|high|critical) [high]: '
  read -r _bs || _bs=""; [ -z "$_bs" ] && _bs="high"

  printf 'Builder CLI command [claude]: '
  read -r _bc || _bc=""; [ -z "$_bc" ] && _bc="claude"

  if [ "$_vm" = "2" ]; then
    printf 'Reviewer CLI command [codex]: '
    read -r _rc || _rc=""; [ -z "$_rc" ] && _rc="codex"
  else
    _rc="$_bc"
  fi

  awk -v vm="$_vm" -v db="$_db" -v rh="$_rh" -v bs="$_bs" -v bc="$_bc" -v rc="$_rc" '
    /^CLAGENTIC_DEFAULT_BRANCH=/    { print "CLAGENTIC_DEFAULT_BRANCH=" db; next }
    /^CLAGENTIC_REPO_HOST=/         { print "CLAGENTIC_REPO_HOST=" rh; next }
    /^CLAGENTIC_BLOCK_SEVERITY=/    { print "CLAGENTIC_BLOCK_SEVERITY=" bs; next }
    /^CLAGENTIC_BUILDER_CMD=/       { print "CLAGENTIC_BUILDER_CMD=" bc; next }
    /^CLAGENTIC_REVIEWER_CMD=/      { print "CLAGENTIC_REVIEWER_CMD=" rc; next }
    /^CLAGENTIC_(AUDITOR|GATE)_CMD=/ { print $0; next }
    { print }
  ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
  mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  if [ "$vm" = "1" ] || [ "$_bc" = "$_rc" ]; then
    warn "Builder and Reviewer both set to '$_bc'. Cross-vendor review surfaces blind spots that same-vendor review shares."
  fi
}

_ensure_local_bin() {
  if [ ! -d "$LOCAL_BIN" ]; then
    mkdir -p "$LOCAL_BIN" \
      || { warn "cannot create $LOCAL_BIN"; return 1; }
  fi
  # Warn if LOCAL_BIN is not on PATH.
  case ":$PATH:" in
    *":$LOCAL_BIN:"*) : ;;
    *)
      warn "$LOCAL_BIN is not on \$PATH"
      warn "Add this line to your shell profile (~/.bashrc, ~/.zshrc, ~/.profile):"
      warn '  export PATH="$HOME/.local/bin:$PATH"'
      ;;
  esac
}

_install_symlink() {
  _CLI_TARGET="$CLAGENTIC_HOME/bin/clagentic-lite"
  if [ ! -f "$_CLI_TARGET" ]; then
    warn "bin/clagentic-lite not found at $_CLI_TARGET — cannot create symlink"
    return 1
  fi
  chmod +x "$_CLI_TARGET"

  if [ -e "$CLI_SYMLINK" ] && [ ! -L "$CLI_SYMLINK" ]; then
    warn "$CLI_SYMLINK exists and is a regular file, not a symlink — refusing to overwrite"
    warn "Remove it manually then re-run \`clagentic-lite init\`"
    return 1
  fi
  # Remove existing symlink (may point to old path) and recreate.
  rm -f "$CLI_SYMLINK"
  ln -s "$_CLI_TARGET" "$CLI_SYMLINK"
  say "symlinked: $CLI_SYMLINK -> $_CLI_TARGET"
}

# ---------------------------------------------------------------- enroll

cmd_enroll() {
  ENROLL_SELF=0
  ENROLL_FORCE=0
  _paths=""

  for _a in "$@"; do
    case "$_a" in
      --self)  ENROLL_SELF=1 ;;
      --force) ENROLL_FORCE=1 ;;
      -*)      warn "unknown flag: $_a" ;;
      *)       _paths="$_paths $_a" ;;
    esac
  done
  export ENROLL_FORCE

  # Default to $PWD if no paths given.
  [ -z "$_paths" ] && _paths="$PWD"

  for _raw_path in $_paths; do
    _enroll_one "$(ds_realpath "$_raw_path")"
  done
}


# _register_wrapper_repo WRAPPER_DIR REPO_PATH
# Appends REPO_PATH to WRAPPER_DIR/.clagentic-project, stamps wrapper CLAUDE.md,
# then enrolls the repo.
_register_wrapper_repo() {
  _rwr_wrapper="$1"
  _rwr_repo="$2"
  printf '%s\n' "$_rwr_repo" >> "$_rwr_wrapper/.clagentic-project"
  _stamp_wrapper_claude_md "$_rwr_wrapper" "$_rwr_repo"
  _enroll_one "$_rwr_repo"
}

_enroll_one() {
  _ep="$1"
  # _ep_orig tracks the original argument so we can write .clagentic-project
  # to the wrapper directory rather than to the enrolled repo.
  _ep_orig="$_ep"

  # Verify it's a git repo. If not, offer wrapper detection (tty only) or
  # fall through to a git init offer.
  if ! git -C "$_ep" rev-parse --git-dir >/dev/null 2>&1; then
    if [ -t 0 ]; then
      # Scan for nested git repos up to 3 levels deep.
      _nested_raw=$(find "$_ep" -maxdepth 3 -name .git -type d 2>/dev/null)
      _nested_count=0
      _nested_list=""
      for _ng in $_nested_raw; do
        # Strip trailing /.git to get repo path.
        _nr="${_ng%/.git}"
        _nested_count=$((_nested_count+1))
        _nested_list="$_nested_list $_nr"
      done

      if [ "$_nested_count" -gt 0 ]; then
        printf 'enroll: %s is not a git repo — found %d nested repo(s):\n' "$_ep" "$_nested_count"
        _i=0
        for _nr in $_nested_list; do
          _i=$((_i+1))
          printf '  %d) %s\n' "$_i" "$_nr"
        done

        if [ "$_nested_count" -eq 1 ]; then
          # Single nested repo: simple Y/n/q prompt.
          _single_repo=""
          for _nr in $_nested_list; do _single_repo="$_nr"; done
          printf 'Enroll it? [Y/n/q(uit)]: '
          read -r _reply || _reply=""
          [ -z "$_reply" ] && _reply="Y"
          case "$_reply" in
            q|Q)
              return 1
              ;;
            n|N)
              # Fall through to git init offer below.
              _nested_count=0
              ;;
            *)
              # Y or blank: enroll the nested repo.
              _register_wrapper_repo "$_ep_orig" "$_single_repo"
              return $?
              ;;
          esac
        else
          # Multiple nested repos: A / # / n / q prompt.
          printf 'Enroll: [A]ll / [#] pick one / [n]one (git init instead) / [q]uit: '
          read -r _reply || _reply=""
          case "$_reply" in
            q|Q)
              return 1
              ;;
            n|N)
              # Fall through to git init offer below.
              _nested_count=0
              ;;
            a|A)
              # Enroll all nested repos.
              for _nr in $_nested_list; do
                _register_wrapper_repo "$_ep_orig" "$_nr"
              done
              return 0
              ;;
            *)
              # Digit: enroll the numbered repo.
              _pick="$_reply"
              _i=0
              _found=""
              for _nr in $_nested_list; do
                _i=$((_i+1))
                if [ "$_i" = "$_pick" ]; then
                  _found="$_nr"
                fi
              done
              if [ -n "$_found" ]; then
                _register_wrapper_repo "$_ep_orig" "$_found"
                return $?
              else
                warn "enroll: invalid selection '$_reply' — skipping"
                return 1
              fi
              ;;
          esac
        fi
      fi

      # git init offer: reached when no nested repos found, or user chose n.
      printf 'enroll: no git repo found under %s.\n' "$_ep"
      printf 'Initialize a new git repo here with `git init`? [Y/n]: '
      read -r _reply || _reply=""
      [ -z "$_reply" ] && _reply="Y"
      case "$_reply" in
        n|N)
          warn "enroll: skipping — no git repo and user declined git init"
          return 1
          ;;
        *)
          git init "$_ep" || { warn "enroll: git init failed for $_ep"; return 1; }
          # Fall through: _ep is now a git repo; the check below will pass.
          ;;
      esac
    else
      # Non-tty: original behavior.
      warn "enroll: $_ep is not a git repository — skipping"
      return 1
    fi
  fi

  _canon=$(ds_realpath "$_ep")
  _home_canon=$(ds_realpath "$CLAGENTIC_HOME")

  # Snake's-head check: refuse to enroll $CLAGENTIC_HOME itself unless --self.
  if [ "$_canon" = "$_home_canon" ] && [ "$ENROLL_SELF" -ne 1 ]; then
    warn "enroll: refusing to enroll \$CLAGENTIC_HOME itself ($_canon)"
    warn "Use --self if you intentionally want the tool to gate itself."
    return 1
  fi

  # Already enrolled check.
  if [ -f "$REGISTRY" ] && grep -qxF "$_canon" "$REGISTRY" 2>/dev/null; then
    if [ "$ENROLL_FORCE" -ne 1 ]; then
      warn "enroll: $_canon is already enrolled (use --force to re-enroll)"
      return 0
    fi
  fi

  # Initialize .clagentic/ DBs in the enrolled repo.
  _dot="$_canon/.clagentic"
  mkdir -p "$_dot" && chmod 755 "$_dot" \
    || { warn "cannot create $_dot"; return 1; }

  CLAGENTIC_PROJECT_ROOT="$_canon" "$CLAGENTIC_HOME/scripts/memory.sh" init
  CLAGENTIC_PROJECT_ROOT="$_canon" "$CLAGENTIC_HOME/scripts/gates.sh" init

  # Stamp hook shims.
  _git_dir=$(git -C "$_canon" rev-parse --git-dir)
  # git rev-parse --git-dir may return a relative path when inside the repo.
  case "$_git_dir" in
    /*) _hooks_dir="$_git_dir/hooks" ;;
    *)  _hooks_dir="$_canon/$_git_dir/hooks" ;;
  esac
  mkdir -p "$_hooks_dir" || true

  stamp_shim pre-commit "$_hooks_dir" || true
  stamp_shim pre-push   "$_hooks_dir" || true

  # Stamp Claude Code integration (.claude/ inside the enrolled repo).
  # settings.json: absolute paths so hook scripts resolve back to CLAGENTIC_HOME.
  # commands/ and agents/: symlinks — pure markdown, no path traversal, stay in
  # sync automatically when the tool updates.
  _claude_settings_template="$SHARE_DIR/hook-shims/claude-settings.template"
  if [ -f "$_claude_settings_template" ]; then
    _claude_dir="$_canon/.claude"
    mkdir -p "$_claude_dir" || { warn "cannot create $_claude_dir"; }

    # Generate settings.json with absolute hook paths substituted in.
    _cs_target="$_claude_dir/settings.json"
    if [ -f "$_cs_target" ] && ! grep -q 'managed-by: clagentic' "$_cs_target" 2>/dev/null; then
      if [ "${ENROLL_FORCE:-0}" = "1" ]; then
        warn "overwriting existing non-clagentic .claude/settings.json (--force)"
      else
        warn "existing .claude/settings.json in $_canon is not clagentic-managed — skipping Claude Code wiring (use --force to overwrite)"
        _claude_dir=""
      fi
    fi

    if [ -n "$_claude_dir" ]; then
      sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_claude_settings_template" > "$_cs_target"

      # Symlink commands/ and agents/ — markdown only, no path traversal.
      ln -sfn "$CLAGENTIC_HOME/.claude/commands" "$_claude_dir/commands"
      ln -sfn "$CLAGENTIC_HOME/.claude/agents"   "$_claude_dir/agents"

      say "wired Claude Code hooks: $_claude_dir"
    fi
  else
    warn "claude-settings.template missing — skipping Claude Code hook wiring"
  fi

  # Stamp CLAUDE.md in the enrolled repo root so Claude Code knows it's
  # operating under the Builder contract. Uses stamp-time substitution for
  # CLAGENTIC_HOME (absolute) and CLAGENTIC_DEFAULT_BRANCH (from env, default main).
  # CLAUDE.md is NOT gitignored — it's a legitimate project file the user may
  # extend. Protected the same way as settings.json: skip unless managed-by
  # marker is present or --force is set.
  _claude_md_template="$SHARE_DIR/hook-shims/CLAUDE.md.template"
  _claude_md_target="$_canon/CLAUDE.md"
  _default_branch="${CLAGENTIC_DEFAULT_BRANCH:-main}"
  if [ -f "$_claude_md_template" ]; then
    if [ -f "$_claude_md_target" ] && ! grep -q 'managed-by: clagentic' "$_claude_md_target" 2>/dev/null; then
      if [ "${ENROLL_FORCE:-0}" = "1" ]; then
        warn "overwriting existing non-clagentic CLAUDE.md (--force)"
      else
        warn "existing CLAUDE.md in $_canon is not clagentic-managed — skipping (use --force to overwrite)"
        _claude_md_template=""
      fi
    fi
    if [ -n "$_claude_md_template" ]; then
      sed -e "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" \
          -e "s|__CLAGENTIC_DEFAULT_BRANCH__|$_default_branch|g" \
          "$_claude_md_template" > "$_claude_md_target"
      say "stamped CLAUDE.md: $_claude_md_target"
    fi
  else
    warn "CLAUDE.md.template missing — skipping Builder contract stamp"
  fi

  # Add .claude/ to the project's .gitignore so the generated wiring is not
  # accidentally committed to the enrolled repo.
  _gitignore="$_canon/.gitignore"
  if [ -f "$_gitignore" ]; then
    if ! grep -qxF '.claude/' "$_gitignore" 2>/dev/null; then
      printf '.claude/\n' >> "$_gitignore"
      say "added .claude/ to $_gitignore"
    fi
  else
    printf '.claude/\n' > "$_gitignore"
    say "created $_gitignore with .claude/"
  fi

  # Register.
  _reg_dir="$(dirname "$REGISTRY")"
  mkdir -p "$_reg_dir" || true

  # Remove any stale entry for this path before appending.
  if [ -f "$REGISTRY" ]; then
    grep -vxF "$_canon" "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true
    mv "$REGISTRY.tmp" "$REGISTRY"
  fi
  printf '%s\n' "$_canon" >> "$REGISTRY"

  say "enrolled: $_canon"
}

# ---------------------------------------------------------------- unenroll

cmd_unenroll() {
  UNENROLL_PURGE=0
  _path="$PWD"

  for _a in "$@"; do
    case "$_a" in
      --purge) UNENROLL_PURGE=1 ;;
      -*)      warn "unknown flag: $_a" ;;
      *)       _path="$_a" ;;
    esac
  done

  _canon=$(ds_realpath "$_path")

  if ! git -C "$_canon" rev-parse --git-dir >/dev/null 2>&1; then
    warn "unenroll: $_canon is not a git repository"
    return 1
  fi

  _git_dir=$(git -C "$_canon" rev-parse --git-dir)
  case "$_git_dir" in
    /*) _hooks_dir="$_git_dir/hooks" ;;
    *)  _hooks_dir="$_canon/$_git_dir/hooks" ;;
  esac

  # Remove only clagentic-owned hooks.
  for _hook in pre-commit pre-push; do
    _hf="$_hooks_dir/$_hook"
    if [ -f "$_hf" ]; then
      if grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
        rm -f "$_hf"
        say "removed hook: $_hf"
      else
        say "skipping non-clagentic hook: $_hf"
      fi
    fi
  done

  # Remove clagentic-owned Claude Code integration (.claude/).
  _cs_file="$_canon/.claude/settings.json"
  if [ -f "$_cs_file" ] && grep -q 'managed-by: clagentic' "$_cs_file" 2>/dev/null; then
    rm -f "$_cs_file"
    # Remove symlinks we own; leave any user-added files.
    rm -f "$_canon/.claude/commands" "$_canon/.claude/agents"
    # Remove .claude/ dir only if now empty.
    rmdir "$_canon/.claude" 2>/dev/null || true
    say "removed Claude Code wiring: $_canon/.claude"
  fi

  # Remove clagentic-managed CLAUDE.md.
  _cm_file="$_canon/CLAUDE.md"
  if [ -f "$_cm_file" ] && grep -q 'managed-by: clagentic' "$_cm_file" 2>/dev/null; then
    rm -f "$_cm_file"
    say "removed CLAUDE.md: $_cm_file"
  fi

  # Deregister.
  if [ -f "$REGISTRY" ]; then
    grep -vxF "$_canon" "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true
    mv "$REGISTRY.tmp" "$REGISTRY"
  fi

  # Purge .clagentic/ if requested.
  if [ "$UNENROLL_PURGE" -eq 1 ]; then
    _dot="$_canon/.clagentic"
    if [ -d "$_dot" ]; then
      rm -rf -- "$_dot"
      say "purged: $_dot"
    fi
  fi

  say "unenrolled: $_canon"
}

# ---------------------------------------------------------------- list

cmd_list() {
  if [ ! -f "$REGISTRY" ]; then
    say "no enrolled repos (registry not found at $REGISTRY)"
    return 0
  fi

  _HR='------------------------------------------------------------------------------------------'
  printf '%-50s  %-24s  %s\n' "PATH" "LAST GATE RUN" "STATUS"
  printf '%s\n' "$_HR"

  while IFS= read -r _rpath; do
    [ -z "$_rpath" ] && continue

    # Determine status.
    _status="ok"
    if [ ! -d "$_rpath" ]; then
      _status="stale"
    elif ! git -C "$_rpath" rev-parse --git-dir >/dev/null 2>&1; then
      _status="not-a-repo"
    else
      _git_dir=$(git -C "$_rpath" rev-parse --git-dir)
      case "$_git_dir" in
        /*) _hooks_dir="$_git_dir/hooks" ;;
        *)  _hooks_dir="$_rpath/$_git_dir/hooks" ;;
      esac
      # Check both shims are present and clagentic-owned.
      for _hook in pre-commit pre-push; do
        _hf="$_hooks_dir/$_hook"
        if [ ! -f "$_hf" ]; then
          _status="hooks missing"
        elif ! grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
          _status="hooks replaced"
        fi
      done
      # Check tool still exists at the baked-in path.
      if [ -f "$_hooks_dir/pre-commit" ]; then
        _baked=$(grep -E '__CLAGENTIC_HOME__|CLAGENTIC_HOME:=' "$_hooks_dir/pre-commit" 2>/dev/null | head -1)
        if [ -z "$_baked" ] && ! grep -q "$CLAGENTIC_HOME" "$_hooks_dir/pre-commit" 2>/dev/null; then
          _status="tool missing"
        fi
      fi
    fi

    # Last gate run from audit.db.
    _db="$_rpath/.clagentic/audit.db"
    _last_run=""
    if [ -f "$_db" ]; then
      _last_run=$(sqlite3 "$_db" "SELECT MAX(ts) FROM gate_runs;" 2>/dev/null || true)
    fi
    [ -z "$_last_run" ] && _last_run="(never)"

    printf '%-50s  %-24s  %s\n' "$_rpath" "$_last_run" "$_status"
  done < "$REGISTRY"
}

# ---------------------------------------------------------------- doctor

cmd_doctor() {
  _ok=0; _fail=0
  _ok()   { printf '  OK   %s\n' "$*"; _ok=$((_ok+1)); }
  _fail() { printf '  FAIL %s\n' "$*" 1>&2; _fail=$((_fail+1)); }

  printf '\n== clagentic-lite doctor ==\n\n'

  # 1. CLAGENTIC_HOME exists and is a valid checkout.
  if [ -f "$CLAGENTIC_HOME/scripts/gates.sh" ]; then
    _ok "CLAGENTIC_HOME=$CLAGENTIC_HOME (valid checkout)"
  else
    _fail "CLAGENTIC_HOME=$CLAGENTIC_HOME (gates.sh missing — is this a clagentic-lite checkout?)"
  fi

  # 2. Symlink correct.
  if [ -L "$CLI_SYMLINK" ]; then
    _sym_target=$(readlink "$CLI_SYMLINK" 2>/dev/null || true)
    if [ "$_sym_target" = "$CLAGENTIC_HOME/bin/clagentic-lite" ]; then
      _ok "$CLI_SYMLINK -> $CLAGENTIC_HOME/bin/clagentic-lite"
    else
      _fail "$CLI_SYMLINK points to $_sym_target (expected $CLAGENTIC_HOME/bin/clagentic-lite)"
    fi
  elif [ -e "$CLI_SYMLINK" ]; then
    _fail "$CLI_SYMLINK exists but is not a symlink"
  else
    _fail "$CLI_SYMLINK missing — run \`clagentic-lite init\`"
  fi

  # 3. LOCAL_BIN on PATH.
  case ":$PATH:" in
    *":$LOCAL_BIN:"*) _ok "$LOCAL_BIN is on \$PATH" ;;
    *) _fail "$LOCAL_BIN is NOT on \$PATH — add: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
  esac

  # 4. Required prereqs.
  printf '\nprerequisites:\n'
  for _tool in sqlite3 git; do
    if command -v "$_tool" >/dev/null 2>&1; then
      _ok "$_tool found"
    else
      _fail "$_tool missing"
    fi
  done
  if command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1; then
    _ok "JSON validator (jq or python3) found"
  else
    _fail "JSON validator missing (need jq or python3)"
  fi
  if command -v python3 >/dev/null 2>&1; then
    _ok "python3 found (W-002 path normalization: full)"
  else
    printf "  WARN python3 not found — W-002 uses POSIX fallback normalization (symlink targets not resolved)\n"
  fi

  # 5. Security tool status (advisory — missing is a warn, not a fail).
  # Tool names come from CLAGENTIC_SECURITY_TOOLS (top of file), same source
  # _run_prereq_checks uses — they cannot drift apart.
  printf '\nsecurity tools:\n'
  for _stool in $CLAGENTIC_SECURITY_TOOLS; do
    if command -v "$_stool" >/dev/null 2>&1; then
      _ok "$_stool found"
    else
      printf '  WARN %s not installed (security gate will block unless ALLOW_MISSING set)\n' "$_stool"
    fi
  done

  # 6. Registry + enrolled repos.
  printf '\nenrolled repos:\n'
  if [ ! -f "$REGISTRY" ]; then
    printf '  (no registry at %s)\n' "$REGISTRY"
  else
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      if [ ! -d "$_rpath" ]; then
        _fail "registered repo no longer exists: $_rpath"
        continue
      fi
      _git_dir=$(git -C "$_rpath" rev-parse --git-dir 2>/dev/null || true)
      if [ -z "$_git_dir" ]; then
        _fail "$_rpath: not a git repo"
        continue
      fi
      case "$_git_dir" in
        /*) _hd="$_git_dir/hooks" ;;
        *)  _hd="$_rpath/$_git_dir/hooks" ;;
      esac
      for _hook in pre-commit pre-push; do
        _hf="$_hd/$_hook"
        if [ ! -f "$_hf" ]; then
          _fail "$_rpath: .git/hooks/$_hook missing"
        elif ! grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
          _fail "$_rpath: .git/hooks/$_hook not clagentic-managed"
        elif ! grep -q "$CLAGENTIC_HOME" "$_hf" 2>/dev/null; then
          _fail "$_rpath: .git/hooks/$_hook points to different CLAGENTIC_HOME (run \`clagentic-lite update\`)"
        else
          _ok "$_rpath: .git/hooks/$_hook OK"
        fi
      done
    done < "$REGISTRY"
  fi


  # 7. Wrapper .clagentic-project pointer files
  printf '\nwrapper .clagentic-project pointers:\n'
  _wrapper_found=0
  if [ -f "$REGISTRY" ]; then
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      _parent=$(dirname "$_rpath")
      _ptr="$_parent/.clagentic-project"
      [ -f "$_ptr" ] || continue
      _wrapper_found=1
      printf '  checking %s\n' "$_ptr"
      while IFS= read -r _ppath; do
        [ -z "$_ppath" ] && continue
        if [ ! -d "$_ppath" ]; then
          _fail "stale pointer in $_ptr: '$_ppath' no longer exists"
        elif ! git -C "$_ppath" rev-parse --git-dir >/dev/null 2>&1; then
          _fail "stale pointer in $_ptr: '$_ppath' is not a git repo"
        elif ! grep -qxF "$_ppath" "$REGISTRY" 2>/dev/null; then
          printf '  WARN  pointer entry %s is not in registry (re-run enroll?)\n' "$_ppath"
        else
          _ok "wrapper pointer: $_ppath"
        fi
      done < "$_ptr"
    done < "$REGISTRY"
  fi
  [ "$_wrapper_found" -eq 0 ] && printf '  (no wrapper .clagentic-project files found)\n'

  # 8. LLM CLI auth probes.
  # Checks that each configured primary CLI is present AND can make a real
  # call. A CLI on PATH that fails auth silently degrades to the chain
  # fallback — this surfaces that before it matters in a gate run.
  # The probe uses a minimal prompt ("ping") with a short timeout so doctor
  # doesn't stall on a slow network. Results are WARN (not FAIL) because a
  # missing or unconfigured CLI causes degraded output, not a hard crash.
  printf '\nLLM CLI auth probes:\n'
  _llm_probe_timeout=10
  # Collect the unique set of primary CLIs across all roles.
  _probed_clis=""
  for _role_pfx in BUILDER REVIEWER AUDITOR GATE SUMMARIZER; do
    _pcmd=$(eval "printf '%s' \"\${CLAGENTIC_${_role_pfx}_CMD:-}\"")
    [ -z "$_pcmd" ] && continue
    # Skip duplicates.
    case " $_probed_clis " in
      *" $_pcmd "*) continue ;;
    esac
    _probed_clis="$_probed_clis $_pcmd"

    if ! command -v "$_pcmd" >/dev/null 2>&1; then
      printf '  WARN %s: not on PATH (roles: %s)\n' "$_pcmd" "$_role_pfx"
      continue
    fi

    # CLI is present — probe auth with a minimal call.
    _probe_out=$(mktemp -t clagentic-doctor-probe.XXXXXX)
    _probe_err=$(mktemp -t clagentic-doctor-probe-err.XXXXXX)
    _probe_ok=0
    case "$_pcmd" in
      claude)
        # claude --print "ping" — succeeds on any auth path (OAuth or API key).
        # CLAGENTIC_DISABLE_RECALL=1 avoids triggering session-start hooks.
        CLAGENTIC_DISABLE_RECALL=1 \
          $DS_TIMEOUT_CMD "$_llm_probe_timeout" claude --print "ping" \
          > "$_probe_out" 2> "$_probe_err" && _probe_ok=1 || true
        ;;
      codex)
        # Mirror the production invoke_codex path: use -o to capture the
        # response (stdout is spinner/progress noise). The prior approach
        # captured stdout, which exercises a different output channel than
        # every real gate call — causing false PASS or false FAIL.
        _probe_o=$(mktemp -t clagentic-doctor-codex-o.XXXXXX)
        $DS_TIMEOUT_CMD "$_llm_probe_timeout" codex exec --skip-git-repo-check \
          --color never -o "$_probe_o" "ping" \
          > "$_probe_err" 2>&1 && _probe_ok=1 || true
        # Strip ANSI from -o file, mirroring invoke_codex's post-processing.
        if [ -s "$_probe_o" ]; then
          sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$_probe_o" > "$_probe_out" 2>/dev/null \
            || cp "$_probe_o" "$_probe_out"
        fi
        rm -f "$_probe_o"
        ;;
      *)
        # Generic: try `-p ping`.
        $DS_TIMEOUT_CMD "$_llm_probe_timeout" "$_pcmd" -p "ping" \
          > "$_probe_out" 2> "$_probe_err" && _probe_ok=1 || true
        ;;
    esac

    if [ "$_probe_ok" = "1" ] && [ -s "$_probe_out" ]; then
      _ok "$_pcmd: auth probe passed"
    else
      # Strip ANSI from error output before showing it.
      _probe_hint=$(sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$_probe_err" 2>/dev/null \
        | grep -v '^[[:space:]]*$' | head -1 | cut -c1-120) || \
        _probe_hint=$(head -1 "$_probe_err" 2>/dev/null | cut -c1-120)
      [ -z "$_probe_hint" ] && _probe_hint="no output (auth expired or model unavailable?)"
      printf '  WARN %s: auth probe failed — %s\n' "$_pcmd" "$_probe_hint"
    fi
    rm -f "$_probe_out" "$_probe_err"
  done
  [ -z "$_probed_clis" ] && printf '  (no LLM CLIs configured — set CLAGENTIC_*_CMD in config)\n'

  # 9. Cross-vendor invariant check.
  # The whole point of clagentic-lite is that Builder and Reviewer are different
  # CLIs so they don't share blind spots. Warn (not fail) when they match —
  # a single-CLI setup still works, but the cross-vendor property is gone.
  printf '\ncross-vendor check:\n'
  _builder_cmd="${CLAGENTIC_BUILDER_CMD:-}"
  _reviewer_cmd="${CLAGENTIC_REVIEWER_CMD:-}"
  if [ -z "$_builder_cmd" ] || [ -z "$_reviewer_cmd" ]; then
    printf '  (Builder or Reviewer CMD not configured — skipping cross-vendor check)\n'
  elif [ "$_builder_cmd" = "$_reviewer_cmd" ]; then
    printf '  WARN Builder and Reviewer both use "%s" — cross-vendor review is disabled.\n' "$_builder_cmd"
    printf '       Set CLAGENTIC_REVIEWER_CMD to a different CLI (e.g. codex vs claude).\n'
    printf '       Or set CLAGENTIC_REVIEWER_REQUIRED=1 to make same-vendor fallback a hard failure.\n'
    printf '       See docs/DESIGN.md §"The three roles" for rationale.\n'
  else
    _ok "Builder=$_builder_cmd / Reviewer=$_reviewer_cmd (cross-vendor OK)"
  fi

  # 10. Memory tunables.
  printf '\nmemory tunables:\n'
  _ok "CLAGENTIC_RECALL_LIMIT=${CLAGENTIC_RECALL_LIMIT:-5 (default)}"
  _ok "CLAGENTIC_RECALL_MAX_CHARS=${CLAGENTIC_RECALL_MAX_CHARS:-1500 (default)}"
  _ok "CLAGENTIC_MEMORY_MAX_ROWS=${CLAGENTIC_MEMORY_MAX_ROWS:-5000 (default)}"

  printf '\n== doctor summary: %s OK, %s FAIL ==\n\n' "$_ok" "$_fail"
  [ "$_fail" -eq 0 ]
}

# ---------------------------------------------------------------- update

# _restamp_repo_artifacts PATH LABEL
# Stamp CLAUDE.md, .claude/settings.json, and wrapper CLAUDE.md for PATH.
# LABEL is appended to each say message (e.g. "" for version-mismatch path,
# " (--restamp)" for the force pass) so callers can distinguish log lines.
# Prints the number of artifacts written to stdout; caller adds to _restamped.
# Version checking is the caller's responsibility — this function always writes.
_restamp_repo_artifacts() {
  _ra_path="$1"
  _ra_label="$2"
  _ra_count=0

  # Re-stamp CLAUDE.md.
  _ra_cm="$_ra_path/CLAUDE.md"
  if [ -f "$_ra_cm" ] && grep -q 'managed-by: clagentic' "$_ra_cm" 2>/dev/null; then
    _ra_cm_template="$SHARE_DIR/hook-shims/CLAUDE.md.template"
    if [ -f "$_ra_cm_template" ]; then
      _ra_default_branch="${CLAGENTIC_DEFAULT_BRANCH:-main}"
      sed -e "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" \
          -e "s|__CLAGENTIC_DEFAULT_BRANCH__|$_ra_default_branch|g" \
          "$_ra_cm_template" > "$_ra_cm"
      say "re-stamped${_ra_label}: $_ra_path/CLAUDE.md"
      _ra_count=$((_ra_count+1))
    fi
  fi

  # Re-stamp .claude/settings.json.
  _ra_cs="$_ra_path/.claude/settings.json"
  if [ -f "$_ra_cs" ] && grep -q 'managed-by: clagentic' "$_ra_cs" 2>/dev/null; then
    _ra_cs_template="$SHARE_DIR/hook-shims/claude-settings.template"
    if [ -f "$_ra_cs_template" ]; then
      sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_ra_cs_template" > "$_ra_cs"
      say "re-stamped${_ra_label}: $_ra_path/.claude/settings.json"
      _ra_count=$((_ra_count+1))
    fi
  fi

  # Re-stamp wrapper CLAUDE.md if the parent dir has a .clagentic-project pointer.
  _ra_wrapper_dir=$(dirname "$_ra_path")
  _ra_wrapper_ptr="$_ra_wrapper_dir/.clagentic-project"
  _ra_wrapper_cm="$_ra_wrapper_dir/CLAUDE.md"
  if [ -f "$_ra_wrapper_ptr" ] && [ -f "$_ra_wrapper_cm" ] && \
     grep -q 'managed-by: clagentic' "$_ra_wrapper_cm" 2>/dev/null; then
    _ra_wcm_template="$SHARE_DIR/hook-shims/CLAUDE.md.wrapper.template"
    if [ -f "$_ra_wcm_template" ]; then
      # Re-build the project table from the pointer file.
      _ra_wcm_repos=$(cat "$_ra_wrapper_ptr" 2>/dev/null | tr '\n' ' ')
      ENROLL_FORCE=1 _stamp_wrapper_claude_md "$_ra_wrapper_dir" "$_ra_wcm_repos" && {
        say "re-stamped wrapper${_ra_label}: $_ra_wrapper_cm"
        _ra_count=$((_ra_count+1))
      }
    fi
  fi

  printf '%d\n' "$_ra_count"
}

cmd_update() {
  RESTAMP=0
  for _arg in "$@"; do
    case "$_arg" in --restamp) RESTAMP=1 ;; esac
  done

  say "updating clagentic-lite at $CLAGENTIC_HOME..."

  # Refuse on dirty working tree.
  if ! git -C "$CLAGENTIC_HOME" diff --quiet 2>/dev/null; then
    die "working tree at $CLAGENTIC_HOME is dirty — stash or commit changes first"
  fi

  # ff-only pull.
  if ! git -C "$CLAGENTIC_HOME" pull --ff-only; then
    die "git pull --ff-only failed (non-fast-forward divergence or no upstream)"
  fi

  # Re-run the same prereq sweep that init runs — pre-PR-#6 this only
  # checked sqlite3 + git, so a clagentic-lite update on a host that had since
  # uninstalled e.g. semgrep would silently leave the gate broken.
  say "checking prerequisites post-update..."
  _run_prereq_checks update

  # Re-stamp shims in registered repos if the template version changed.
  if [ ! -f "$REGISTRY" ]; then
    say "no enrolled repos to re-stamp"
    return 0
  fi

  _restamped=0
  _would_restamp=0
  while IFS= read -r _rpath; do
    [ -z "$_rpath" ] && continue
    [ -d "$_rpath" ] || continue
    _git_dir=$(git -C "$_rpath" rev-parse --git-dir 2>/dev/null || true)
    [ -z "$_git_dir" ] && continue
    case "$_git_dir" in
      /*) _hd="$_git_dir/hooks" ;;
      *)  _hd="$_rpath/$_git_dir/hooks" ;;
    esac
    for _hook in pre-commit pre-push; do
      _hf="$_hd/$_hook"
      _installed_ver=$(shim_version "$_hf")
      if [ "$_installed_ver" != "$SHIM_VERSION" ]; then
        _would_restamp=1
        ENROLL_FORCE=0 stamp_shim "$_hook" "$_hd" && {
          say "re-stamped: $_rpath .git/hooks/$_hook ($_installed_ver -> $SHIM_VERSION)"
          _restamped=$((_restamped+1))
        }
      fi
    done

    # Re-stamp .claude/settings.json, CLAUDE.md, and wrapper CLAUDE.md if any
    # version changed.  _restamp_repo_artifacts handles all three writes; we
    # check versions here to decide whether to call it and to set _would_restamp.
    # Guards mirror the originals: only compare version when the file exists and
    # carries the managed-by marker (or, for wrapper, when the pointer exists).
    _need_restamp=0
    _cs_file="$_rpath/.claude/settings.json"
    if [ -f "$_cs_file" ] && grep -q 'managed-by: clagentic' "$_cs_file" 2>/dev/null; then
      _cs_ver=$(claude_settings_version "$_cs_file")
      [ "$_cs_ver" != "$CLAUDE_SETTINGS_VERSION" ] && _need_restamp=1
    fi
    _cm_file="$_rpath/CLAUDE.md"
    if [ -f "$_cm_file" ] && grep -q 'managed-by: clagentic' "$_cm_file" 2>/dev/null; then
      _cm_ver=$(claude_md_version "$_cm_file")
      [ "$_cm_ver" != "$CLAUDE_MD_VERSION" ] && _need_restamp=1
    fi
    _vck_wrapper_dir=$(dirname "$_rpath")
    _vck_wrapper_ptr="$_vck_wrapper_dir/.clagentic-project"
    _vck_wrapper_cm="$_vck_wrapper_dir/CLAUDE.md"
    if [ -f "$_vck_wrapper_ptr" ] && [ -f "$_vck_wrapper_cm" ] && \
       grep -q 'managed-by: clagentic' "$_vck_wrapper_cm" 2>/dev/null; then
      _wcm_ver=$(claude_md_version "$_vck_wrapper_cm")
      [ "$_wcm_ver" != "$CLAUDE_MD_VERSION" ] && _need_restamp=1
    fi
    if [ "$_need_restamp" -eq 1 ]; then
      _would_restamp=1
      _n=$(_restamp_repo_artifacts "$_rpath" "")
      _restamped=$((_restamped+_n))
    fi

  done < "$REGISTRY"

  # Interactive prompt: if nothing was auto-stamped and --restamp not passed,
  # offer to re-stamp anyway when running on a tty.
  if [ "$_would_restamp" -eq 0 ] && [ "$RESTAMP" -eq 0 ] && [ -t 0 ] && [ -f "$REGISTRY" ]; then
    _managed_count=0
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      [ -d "$_rpath" ] || continue
      [ -f "$_rpath/CLAUDE.md" ] && grep -q 'managed-by: clagentic' "$_rpath/CLAUDE.md" 2>/dev/null && \
        _managed_count=$((_managed_count+1))
    done < "$REGISTRY"
    if [ "$_managed_count" -gt 0 ]; then
      printf '[clagentic-lite] All %d enrolled repo(s) already at CLAUDE.md %s.\n' "$_managed_count" "$CLAUDE_MD_VERSION"
      printf 'Re-stamp CLAUDE.md and settings.json anyway? [y/N]: '
      read -r _restamp_reply || _restamp_reply=""
      case "$_restamp_reply" in
        y|Y|yes|YES) RESTAMP=1 ;;
      esac
    fi
  fi

  # --restamp pass: force re-stamp all managed artifacts regardless of version.
  if [ "$RESTAMP" -eq 1 ] && [ -f "$REGISTRY" ]; then
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      [ -d "$_rpath" ] || continue
      _n=$(_restamp_repo_artifacts "$_rpath" " (--restamp)")
      _restamped=$((_restamped+_n))
    done < "$REGISTRY"
  fi

  say "update complete (re-stamped $_restamped artifact(s))"
}

# ---------------------------------------------------------------- dispatch

case "${1:-}" in
  init)     shift; cmd_init "$@" ;;
  enroll)   shift; cmd_enroll "$@" ;;
  unenroll) shift; cmd_unenroll "$@" ;;
  list)     cmd_list ;;
  doctor)   cmd_doctor ;;
  update)   shift; cmd_update "$@" ;;
  recall)
    # recall <keywords...>  — search session memory for matching summaries.
    # Thin dispatch to scripts/memory.sh recall; honors CLAGENTIC_RECALL_LIMIT
    # and CLAGENTIC_RECALL_MAX_CHARS.
    shift
    exec "$SCRIPTS_DIR/memory.sh" recall "$@"
    ;;
  remember)
    # remember "<note>" [tags]  — store a manual memory entry.
    # Thin dispatch to scripts/memory.sh log-turn with source='manual'.
    # Does NOT add new plumbing; 'manual' source is already supported.
    shift
    if [ $# -eq 0 ]; then
      printf 'usage: clagentic-lite remember "<note>" [tags]\n' 1>&2
      exit 1
    fi
    _note="$1"; shift
    _tags="${*:-}"
    exec "$SCRIPTS_DIR/memory.sh" log-turn "$_note" "$_tags" "manual"
    ;;
  "")
    printf 'usage: clagentic-lite <subcommand> [args]\n'
    printf 'subcommands: init, enroll, unenroll, list, doctor, update [--restamp], recall, remember\n'
    exit 1
    ;;
  *)
    printf 'clagentic-lite: unknown subcommand: %s\n' "$1" 1>&2
    printf 'usage: clagentic-lite <subcommand> [args]\n'
    printf 'subcommands: init, enroll, unenroll, list, doctor, update [--restamp], recall, remember\n'
    exit 1
    ;;
esac
