#!/bin/sh
# clagentic-lite :: CLI entry point
# Clone once to $CLAGENTIC_HOME. Use this CLI for all lifecycle operations.
#
# Subcommands:
#   init [--reconfigure]          first-time setup: prereqs, global config, symlink, plugin install
#   enroll [--self] [--force] [PATH...]   wire hooks + init DBs for a repo
#   unenroll [--purge] [PATH]             remove clagentic hooks, deregister
#   list                                  show enrolled repos + status
#   doctor                                diagnostics punch list
#   update [--restamp]                    git pull + re-prereq + re-stamp shims + plugin update
#   recall [keywords...]                  search session memory for matching summaries
#   remember "<note>" [tags]              store a manual memory entry
#   show memory|gates [N]         pretty-print last N rows from .clagentic/ DBs
#   export [--output PATH]        write self-contained HTML report of memory + gates
#   gates <subcmd> [args...]      proxy to $CLAGENTIC_HOME/scripts/gates.sh
#                                 (ship, review, adversarial, digest, status, tail, ...)
#
# Design: tool is cloned once (default: ~/.clagentic-lite, override via
# $CLAGENTIC_HOME). Per-repo enrollment writes .clagentic/{audit,memory}.db,
# thin shims in .git/hooks/ that call back to $CLAGENTIC_HOME/scripts/, and
# .claude/settings.json + symlink to .claude/commands so Claude Code picks up
# hook wiring and slash commands.
# The five role agents (builder, reviewer, auditor, merge-gate, troubleshooter) and
# commentary skills (/infosec-rt, /eng-consult) are installed globally via
# 'claude plugin install' at init time — no per-repo copies.
# The tool repo itself is never the thing under gates by default.

set -e

# Resolve CLAGENTIC_HOME: env var wins, else default.
: "${CLAGENTIC_HOME:=$HOME/.clagentic-lite}"
export CLAGENTIC_HOME

# Source platform shims from our own install tree.
SCRIPTS_DIR="$CLAGENTIC_HOME/scripts"
if [ ! -f "$SCRIPTS_DIR/platform.sh" ]; then
  # Bootstrap path: being invoked before init has verified $CLAGENTIC_HOME.
  # Try to resolve from this script's own location.
  _SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
  SCRIPTS_DIR="$(dirname "$_SELF_DIR")/scripts"
fi
if [ ! -f "$SCRIPTS_DIR/platform.sh" ]; then
  printf 'clagentic-lite: cannot find scripts/platform.sh in %s\n' "$CLAGENTIC_HOME" >&2
  printf 'Set CLAGENTIC_HOME to the clagentic-lite checkout directory.\n' >&2
  exit 1
fi
. "$SCRIPTS_DIR/platform.sh"

SHARE_DIR="$CLAGENTIC_HOME/share"
REGISTRY="$HOME/.local/state/clagentic/registry"
GLOBAL_CONFIG="$HOME/.config/clagentic/config"
LOCAL_BIN="$HOME/.local/bin"
CLI_SYMLINK="$LOCAL_BIN/clagentic-lite"

# Shim template version marker. Bump this string when the template content
# changes so `clagentic-lite update` knows to re-stamp enrolled repos.
SHIM_VERSION="v1"

# Claude Code artifact version markers. Bump when the corresponding template
# changes so `clagentic-lite update` re-stamps enrolled repos automatically.
CLAUDE_SETTINGS_VERSION="v3"
# CLAUDE_MD_VERSION is retired — replaced by three narrower constants below.
# The variable is kept as a tombstone so doctor/update version-compare calls
# against old installed files continue to work during the transition period.
CLAUDE_MD_VERSION="v9"
# Thin enrollment notice in the committed repo CLAUDE.md. Bump only on
# notice text changes — stable by design.
CLAUDE_NOTICE_VERSION="v2"
# Local .clagentic/builder-contract.md — full builder rules, never committed.
# Bump on any content change; cheap restamp (gitignored).
CLAUDE_CONTRACT_VERSION="v1"
# Local wrapper CLAUDE.md — rich local dashboard, never committed.
# Bump on any template change; cheap restamp (local).
CLAUDE_WRAPPER_VERSION="v1"

# Single source of truth for the security-gate tool list. Adding a new
# scanner means editing this one line — _run_prereq_checks (init/update)
# and cmd_doctor both iterate this list, so they stay in sync.
# Space-separated POSIX-sh string (no arrays).
CLAGENTIC_SECURITY_TOOLS="gitleaks semgrep osv-scanner"

say()  { printf '[clagentic-lite] %s\n' "$*"; }
warn() { printf '[clagentic-lite] WARN: %s\n' "$*" 1>&2; }
die()  { printf '[clagentic-lite] ERROR: %s\n' "$*" 1>&2; exit 1; }

# ---------------------------------------------------------------- helpers

# Portable absolute path resolution (no readlink -f on macOS by default).
ds_realpath() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1" 2>/dev/null || printf '%s' "$1"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$1" 2>/dev/null
  else
    # POSIX fallback: cd to dir, print pwd + basename.
    _rp_dir="$(dirname "$1")"
    _rp_base="$(basename "$1")"
    (cd "$_rp_dir" 2>/dev/null && printf '%s/%s' "$(pwd)" "$_rp_base") || printf '%s' "$1"
  fi
}

# Read the version marker from an installed hook shim.
shim_version() {
  _sv_file="$1"
  [ -f "$_sv_file" ] || { printf ''; return; }
  awk '/clagentic-lite hook shim/ { print; exit }' "$_sv_file" 2>/dev/null | sed 's/.*· \(v[^ ]*\) ·.*/\1/'
}

# Read the version marker from an installed .claude/settings.json.
# Looks for "clagentic-settings-version: vN" in the $comment field.
claude_settings_version() {
  _csv_file="$1"
  [ -f "$_csv_file" ] || { printf ''; return; }
  grep -o 'clagentic-settings-version: v[^ ·"]*' "$_csv_file" 2>/dev/null | sed 's/clagentic-settings-version: //'
}

# Read the version marker from an installed CLAUDE.md.
# Handles both old marker (clagentic-claude-md-version) and the new notice
# marker (clagentic-notice-version) so version checks work during transition.
claude_md_version() {
  _cmv_file="$1"
  [ -f "$_cmv_file" ] || { printf ''; return; }
  grep -o 'clagentic-claude-md-version: v[^ ·>]*' "$_cmv_file" 2>/dev/null | sed 's/clagentic-claude-md-version: //'
}

# Read the thin-notice version from an installed repo CLAUDE.md.
claude_notice_version() {
  _cnv_file="$1"
  [ -f "$_cnv_file" ] || { printf ''; return; }
  grep -o 'clagentic-notice-version: v[^ ·>]*' "$_cnv_file" 2>/dev/null | sed 's/clagentic-notice-version: //'
}

# Read the builder-contract version from .clagentic/builder-contract.md.
claude_contract_version() {
  _ccv_file="$1"
  [ -f "$_ccv_file" ] || { printf ''; return; }
  grep -o 'clagentic-contract-version: v[^ ·>]*' "$_ccv_file" 2>/dev/null | sed 's/clagentic-contract-version: //'
}

# Read the wrapper CLAUDE.md version.
claude_wrapper_version() {
  _cwv_file="$1"
  [ -f "$_cwv_file" ] || { printf ''; return; }
  grep -o 'clagentic-wrapper-version: v[^ ·>]*' "$_cwv_file" 2>/dev/null | sed 's/clagentic-wrapper-version: //'
}

# Stamp a hook shim from share/hook-shims/<name>.template into a repo's
# .git/hooks/<name>. Substitutes __CLAGENTIC_HOME__ with the actual path.
# Args: TEMPLATE_NAME HOOKS_DIR
# Returns: 0 stamped, 1 refused (existing non-clagentic hook, no --force)
stamp_shim() {
  _ss_name="$1"
  _ss_hooks_dir="$2"
  _ss_target="$_ss_hooks_dir/$_ss_name"
  _ss_template="$SHARE_DIR/hook-shims/${_ss_name}.template"
  [ -f "$_ss_template" ] || { warn "template missing: $_ss_template"; return 1; }

  # If the hook file exists and is NOT clagentic-owned, refuse unless --force.
  if [ -f "$_ss_target" ]; then
    if grep -q 'managed-by: clagentic' "$_ss_target" 2>/dev/null; then
      : # clagentic-owned — overwrite silently
    elif [ "${ENROLL_FORCE:-0}" = "1" ]; then
      warn "overwriting existing non-clagentic hook at $_ss_target (--force)"
    else
      warn "existing hook at $_ss_target is not clagentic-managed — skipping (use --force to overwrite)"
      return 1
    fi
  fi

  # Write shim: substitute __CLAGENTIC_HOME__ with the real path.
  sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_ss_template" > "$_ss_target"
  chmod +x "$_ss_target"
  return 0
}

# Stamp a wrapper-flavored CLAUDE.md into a non-git wrapper directory.
# Args: WRAPPER_DIR  ENROLLED_REPOS (space-separated absolute paths)
# No hook wiring — hooks are git-repo-rooted and must not fire from wrapper CWD.
# Skips if a non-clagentic CLAUDE.md already exists (unless ENROLL_FORCE=1).
_stamp_wrapper_claude_md() {
  _wcd="$1"; _wcd_repos="$2"
  _wcd_template="$SHARE_DIR/hook-shims/CLAUDE.md.wrapper.template"
  [ -f "$_wcd_template" ] || { warn "CLAUDE.md.wrapper.template missing — skipping wrapper CLAUDE.md"; return 0; }

  _wcd_target="$_wcd/CLAUDE.md"
  if [ -f "$_wcd_target" ] && ! grep -q 'managed-by: clagentic' "$_wcd_target" 2>/dev/null; then
    if [ "${ENROLL_FORCE:-0}" = "1" ]; then
      warn "overwriting existing non-clagentic CLAUDE.md in wrapper $_wcd (--force)"
    else
      warn "existing CLAUDE.md in wrapper $_wcd is not clagentic-managed — skipping (use --force to overwrite)"
      return 0
    fi
  fi

  # Generate the file directly — multiline table substitution via sed is
  # fragile (newlines, special chars in paths). Read template line by line;
  # replace the token line with the generated table.
  {
    while IFS= read -r _tmpl_line; do
      case "$_tmpl_line" in
        *__WRAPPER_PROJECT_TABLE__*)
          # Include last-gate-run column when sqlite3 is available (best-effort).
          if command -v sqlite3 >/dev/null 2>&1; then
            printf '| Subfolder | Last gate run | Status |\n'
            printf '|---|---|---|\n'
            for _wr in $_wcd_repos; do
              _rel="${_wr#$_wcd}"
              _rel="${_rel#/}"
              [ -z "$_rel" ] && _rel="$_wr"
              _wcd_db="$_wr/.clagentic/audit.db"
              _wcd_last=""
              if [ -f "$_wcd_db" ]; then
                _wcd_last=$(sqlite3 "$_wcd_db" "SELECT MAX(ts) FROM gate_runs;" 2>/dev/null || true)
              fi
              [ -z "$_wcd_last" ] && _wcd_last="never"
              # Check hook presence for a quick health indicator.
              _wcd_status="ok"
              _wcd_git_dir=$(git -C "$_wr" rev-parse --git-dir 2>/dev/null || true)
              if [ -z "$_wcd_git_dir" ]; then
                _wcd_status="not-a-repo"
              else
                case "$_wcd_git_dir" in
                  /*) _wcd_hd="$_wcd_git_dir/hooks" ;;
                  *)  _wcd_hd="$_wr/$_wcd_git_dir/hooks" ;;
                esac
                if [ ! -f "$_wcd_hd/pre-commit" ]; then
                  _wcd_status="hooks missing"
                fi
              fi
              printf '| `%s` | %s | %s |\n' "$_rel" "$_wcd_last" "$_wcd_status"
            done
          else
            # sqlite3 not available — simpler table without last-gate column.
            printf '| Subfolder | Absolute path |\n'
            printf '|---|---|\n'
            for _wr in $_wcd_repos; do
              _rel="${_wr#$_wcd}"
              _rel="${_rel#/}"
              [ -z "$_rel" ] && _rel="$_wr"
              printf '| `%s` | `%s` |\n' "$_rel" "$_wr"
            done
          fi
          ;;
        *)
          printf '%s\n' "$_tmpl_line"
          ;;
      esac
    done < "$_wcd_template"
  } > "$_wcd_target"
  say "stamped wrapper CLAUDE.md: $_wcd_target" >&2
}

# ---------------------------------------------------------------- prereq helpers
#
# Single source of truth for "what tools does clagentic-lite need". cmd_init,
# cmd_update, and cmd_doctor all call into here so adding a new required tool
# means editing one function, not three.
#
# Required tools: hard prereqs. Init/update will offer to install; doctor
# will fail if absent.
# Security tools: needed by the secrets/sast/deps gates. Skippable via the
# ALLOW_MISSING_* env vars; doctor reports them as WARN, not FAIL.
# JSON validator: jq OR python3 satisfies the requirement (hooks fall back
# to python3 when jq is absent). Handled separately because of the "either-or".

# Look up per-OS install hints for a security tool, keyed off CLAGENTIC_SECURITY_TOOLS.
# Echoes "LINUX_HINT|DARWIN_HINT" — caller splits on '|'. Returns 1 for unknown
# names (so adding a name to CLAGENTIC_SECURITY_TOOLS without adding a hint case
# here fails loudly instead of silently degrading).
# semgrep's linux hint is dynamic (PEP 668 picker); the others are static.
_security_tool_hints() {
  _STH_NAME="$1"
  case "$_STH_NAME" in
    gitleaks)
      printf '%s|%s' \
        "see https://github.com/gitleaks/gitleaks#installing" \
        "brew install gitleaks"
      ;;
    semgrep)
      printf '%s|%s' "$(_semgrep_hint_linux)" "brew install semgrep"
      ;;
    osv-scanner)
      printf '%s|%s' \
        "see https://google.github.io/osv-scanner/installation/" \
        "brew install osv-scanner"
      ;;
    *)
      return 1
      ;;
  esac
}

# Pick the right semgrep install hint for this host. PEP 668 (Debian 12+,
# Ubuntu 23.04+, modern WSL) refuses unmanaged pip installs against system
# Python — suggesting `pip install --user` there produces the
# "externally-managed-environment" error. Order of preference:
#   1. pipx present                       -> pipx install semgrep
#   2. no pipx, Python NOT PEP-668        -> python3 -m pip install --user semgrep
#   3. no pipx, Python IS PEP-668 managed -> apt install pipx (then re-run init)
#   4. no pipx, no python3                -> point at vendor docs
_semgrep_hint_linux() {
  if command -v pipx >/dev/null 2>&1; then
    printf '%s' "pipx install semgrep"
    return
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf '%s' "see https://semgrep.dev/docs/getting-started/"
    return
  fi
  set -- /usr/lib/python3*/EXTERNALLY-MANAGED /usr/lib/python3/EXTERNALLY-MANAGED
  for _f in "$@"; do
    if [ -e "$_f" ]; then
      printf '%s' "apt install pipx  # then re-run \`clagentic-lite init\` (PEP 668 — system python refuses pip --user)"
      return
    fi
  done
  printf '%s' "python3 -m pip install --user semgrep"
}

# _run_prereq_checks MODE
#   MODE = "init"   -> ds_offer_install for required + security tools.
#   MODE = "update" -> same (so post-update checks match init coverage).
# Sets DS_CHECK_MISSING (required tools only) and DS_PENDING_INSTALLS.
# Prints the collated still-to-install summary at the end.
_run_prereq_checks() {
  _RPC_MODE="${1:-init}"
  DS_CHECK_MISSING=0; export DS_CHECK_MISSING
  ds_pending_reset

  # Required: sqlite3, git.
  ds_offer_install sqlite3 "apt install sqlite3" "brew install sqlite" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))
  ds_offer_install git "apt install git" "xcode-select --install" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))

  # Required: jq OR python3. Either one satisfies.
  if command -v jq >/dev/null 2>&1; then
    printf '  %-15s found: %s\n' "jq" "$(command -v jq)"
  elif command -v python3 >/dev/null 2>&1; then
    printf '  %-15s found (python3 fallback): %s\n' "jq" "$(command -v python3)"
  else
    ds_offer_install jq "apt install jq" "brew install jq" || DS_CHECK_MISSING=$((DS_CHECK_MISSING+1))
    warn "no JSON validator — PreToolUse hooks will fail closed until jq or python3 is installed"
  fi

  # Security gate tools — required unless ALLOW_MISSING_* opts in. Not counted
  # toward DS_CHECK_MISSING because the user might legitimately opt out.
  # List of names lives in CLAGENTIC_SECURITY_TOOLS (top of file); hints come
  # from _security_tool_hints, which fails loudly if a name lacks a case
  # (catches "added to list but forgot to add hints" drift).
  for _stool in $CLAGENTIC_SECURITY_TOOLS; do
    _sthints=$(_security_tool_hints "$_stool") || \
      die "internal: no install hint for security tool '$_stool' (update _security_tool_hints in bin/clagentic-lite)"
    _stl="${_sthints%%|*}"
    _std="${_sthints##*|}"
    ds_offer_install "$_stool" "$_stl" "$_std" || true
  done

  # Nice-to-have: timeout / gtimeout.
  if ! command -v timeout >/dev/null 2>&1 && ! command -v gtimeout >/dev/null 2>&1; then
    printf '  %-15s MISSING (optional) — install: %s\n' "timeout" \
      "brew install coreutils (macOS) | apt install coreutils (Linux)"
    warn "no timeout/gtimeout — LLM calls will run without per-call timeouts"
  fi

  # Single collated summary at the bottom of the run.
  ds_pending_summary

  if [ "$DS_CHECK_MISSING" -gt 0 ]; then
    case "$_RPC_MODE" in
      update)
        say "$DS_CHECK_MISSING required tool(s) still missing post-update — fix them before next gate run"
        ;;
      *)
        say "$DS_CHECK_MISSING required tool(s) still missing — fix them and re-run \`clagentic-lite init\`"
        ;;
    esac
    if [ "${CLAGENTIC_STRICT_PREFLIGHT:-0}" = "1" ]; then
      die "strict preflight: $DS_CHECK_MISSING required tool(s) missing"
    fi
  fi
}

# ---------------------------------------------------------------- init

cmd_init() {
  RECONFIGURE=0
  for _arg in "$@"; do
    case "$_arg" in --reconfigure) RECONFIGURE=1 ;; esac
  done

  say "clagentic-lite init"
  say "CLAGENTIC_HOME: $CLAGENTIC_HOME"

  # 1. Verify this is a clagentic-lite checkout.
  if [ ! -f "$CLAGENTIC_HOME/scripts/gates.sh" ]; then
    die "$CLAGENTIC_HOME does not look like a clagentic-lite checkout (scripts/gates.sh missing)"
  fi

  # 1.5. Freshness check. If CLAGENTIC_HOME is a git checkout and the local
  # branch is behind its upstream, nudge the user to run `clagentic-lite update`
  # before continuing — otherwise init runs against stale code (the silent
  # footgun that bit early users when PRs #3/#4/#5 landed and they kept
  # re-running init without pulling).
  # Skippable with CLAGENTIC_SKIP_FETCH=1 for offline use, and silently
  # tolerant of failure (no upstream, no network, not a worktree, etc.).
  if [ "${CLAGENTIC_SKIP_FETCH:-0}" != "1" ] \
      && git -C "$CLAGENTIC_HOME" rev-parse --git-dir >/dev/null 2>&1; then
    # Best-effort fetch; suppress output. Network failures are non-fatal.
    git -C "$CLAGENTIC_HOME" fetch --quiet 2>/dev/null || true
    _BRANCH=$(git -C "$CLAGENTIC_HOME" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    _UPSTREAM=$(git -C "$CLAGENTIC_HOME" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
    if [ -n "$_BRANCH" ] && [ -n "$_UPSTREAM" ]; then
      _BEHIND=$(git -C "$CLAGENTIC_HOME" rev-list --count "HEAD..$_UPSTREAM" 2>/dev/null || echo 0)
      if [ "$_BEHIND" -gt 0 ] 2>/dev/null; then
        warn "$CLAGENTIC_HOME is $_BEHIND commit(s) behind $_UPSTREAM — run \`clagentic-lite update\` to pick up the latest fixes before re-running init"
      fi
    fi
  fi

  # 2. Prereq detection — shared helper used by init / update / doctor.
  #    On a re-run with config already present, the prereq sweep still runs
  #    (always useful), but the two-question front door is skipped — silence
  #    when nothing will change.
  say "checking prerequisites..."
  _run_prereq_checks init

  # 3. Two-question front door. Skip entirely when global config already
  #    exists and --reconfigure was not passed — otherwise re-runs of init
  #    pointlessly ask "Accept all defaults? [Y/n]" every time.
  if [ -f "$GLOBAL_CONFIG" ] && [ "$RECONFIGURE" -eq 0 ]; then
    say "global config already exists at $GLOBAL_CONFIG (use --reconfigure to re-prompt)"
  else
    _write_global_config
  fi

  # 4. Ensure ~/.local/bin/ exists.
  _ensure_local_bin

  # 5. Symlink ~/.local/bin/clagentic-lite -> $CLAGENTIC_HOME/bin/clagentic-lite.
  _install_symlink

  # 6. Register the clagentic-lite marketplace and install the agent plugin so
  # Claude Code discovers the five role agents globally in every session.
  # Sequence: marketplace add (registers source) -> plugin install by name.
  # 'claude plugin marketplace add' is idempotent — re-running init is safe.
  if command -v claude >/dev/null 2>&1; then
    # Best-effort pre-registration so the subsequent list check can find the plugin
    # even when the marketplace was not previously registered.
    claude plugin marketplace add "$CLAGENTIC_HOME" --scope user 2>/dev/null || true

    # Migration: uninstall the old plugin name (clagentic-lite-agents, shipped before v1.2.0)
    # before checking for or installing the current name. The old name contains "clagentic-lite"
    # as a substring, so a naive grep match would incorrectly treat it as "already installed"
    # and skip the install of the renamed plugin.
    if claude plugin list 2>/dev/null | grep -qE '(^|[[:space:]])clagentic-lite-agents(@|[[:space:]]|$)'; then
      say "migrating: removing old plugin name clagentic-lite-agents..."
      claude plugin uninstall "clagentic-lite-agents@clagentic-lite" 2>/dev/null || \
        claude plugin uninstall "clagentic-lite-agents" 2>/dev/null || \
        warn "could not uninstall old plugin clagentic-lite-agents — remove manually: claude plugin uninstall clagentic-lite-agents"
    fi

    # Exact-match check: grep for the new plugin name as a whole token, not a substring.
    # "clagentic-lite-agents" contains "clagentic-lite" as a prefix; substring grep would
    # falsely match it and skip the install of the renamed plugin.
    if claude plugin list 2>/dev/null | grep -qE '(^|[[:space:]])clagentic-lite(@|[[:space:]]|$)'; then
      say "plugin clagentic-lite already installed"
    else
      if claude plugin marketplace add "$CLAGENTIC_HOME" --scope user; then
        if claude plugin install "clagentic-lite@clagentic-lite"; then
          say "installed plugin: clagentic-lite (agents and skills available globally)"
        else
          warn "claude plugin install failed — run manually: claude plugin install clagentic-lite@clagentic-lite"
        fi
      else
        warn "claude plugin marketplace add failed — run manually: claude plugin marketplace add $CLAGENTIC_HOME && claude plugin install clagentic-lite@clagentic-lite"
      fi
    fi
  else
    warn "claude not on PATH — skipping plugin install; after adding to PATH run: claude plugin marketplace add $CLAGENTIC_HOME && claude plugin install clagentic-lite@clagentic-lite"
  fi

  say "init complete"
  if [ -f "$GLOBAL_CONFIG" ] && [ "$RECONFIGURE" -eq 0 ]; then
    say "(no config changes — re-ran prereq + symlink only)"
  fi
  say "next: cd into any repo you want gates on, then run \`clagentic-lite enroll\`"
}

_write_global_config() {
  # Q1: accept all defaults?
  ACCEPT_DEFAULTS="y"
  if [ -t 0 ]; then
    printf 'Accept all defaults? [Y/n]: '
    read -r _q1 || _q1=""
    [ -z "$_q1" ] && _q1="y"
    case "$_q1" in y|Y|yes|YES) ACCEPT_DEFAULTS="y" ;; *) ACCEPT_DEFAULTS="n" ;; esac
  fi

  # Q2: vendor mode (only asked when accepting defaults or in granular mode).
  VENDOR_MODE="2"
  if [ "$ACCEPT_DEFAULTS" = "y" ] && [ -t 0 ]; then
    printf 'Vendor mode?  [1] Claude only  [2] Claude + Codex (cross-vendor, default): '
    read -r _q2 || _q2=""
    [ -z "$_q2" ] && _q2="2"
    VENDOR_MODE="$_q2"
  fi

  # Start with the example as the base.
  _CONFIG_SRC="$SHARE_DIR/config.example"
  [ -f "$_CONFIG_SRC" ] || die "share/config.example missing — is \$CLAGENTIC_HOME correct?"

  # Prepare destination directory.
  _config_dir="$(dirname "$GLOBAL_CONFIG")"
  if [ ! -d "$_config_dir" ]; then
    mkdir -p "$_config_dir" && chmod 700 "$_config_dir" \
      || { warn "cannot create $_config_dir"; return 1; }
  fi

  cp "$_CONFIG_SRC" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  # Stamp CLAGENTIC_HOME.
  awk -v home="$CLAGENTIC_HOME" '
    /^CLAGENTIC_HOME=/ { print "CLAGENTIC_HOME=" home; next }
    { print }
  ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
  mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  # Apply vendor mode: if mode=1 (Claude only), set all roles to claude.
  if [ "$VENDOR_MODE" = "1" ]; then
    awk '
      /^CLAGENTIC_(REVIEWER|AUDITOR)_CMD=/ { sub(/=.*/, "=claude"); }
      /^CLAGENTIC_(REVIEWER|AUDITOR)_CHAIN=/ { sub(/=.*/, "=claude:default"); }
      { print }
    ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
    mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
    chmod 600 "$GLOBAL_CONFIG"
    warn "Builder and Reviewer both set to 'claude'. Cross-vendor review surfaces blind spots that same-vendor review shares."
  fi

  # Granular flow: max 6 prompts when user declined all-defaults.
  if [ "$ACCEPT_DEFAULTS" = "n" ] && [ -t 0 ]; then
    _granular_config_prompts
  fi

  # Stamp bleed-patterns template if not already present. This is a side-by-side
  # companion to config — it lives in the same directory but is not gitignored
  # (patterns are private, so the file is never committed to the public repo).
  # Skip silently if it already exists — do not overwrite a user's pattern list.
  _BLEED_SRC="$SHARE_DIR/bleed-patterns.example"
  _BLEED_DEST="$(dirname "$GLOBAL_CONFIG")/bleed-patterns"
  if [ -f "$_BLEED_SRC" ] && [ ! -f "$_BLEED_DEST" ]; then
    cp "$_BLEED_SRC" "$_BLEED_DEST"
    chmod 600 "$_BLEED_DEST"
    say "wrote bleed-patterns template: $_BLEED_DEST (add your private patterns there)"
  fi

  say "wrote global config: $GLOBAL_CONFIG (chmod 600)"
}

_granular_config_prompts() {
  # 6 prompts max: vendor mode, default branch, repo host, block severity,
  # builder primary, reviewer primary.
  printf 'Vendor mode?  [1] Claude only  [2] Claude + Codex (cross-vendor, default): '
  read -r _vm || _vm=""; [ -z "$_vm" ] && _vm="2"

  printf 'Default branch [main]: '
  read -r _db || _db=""; [ -z "$_db" ] && _db="main"

  printf 'Repo host (github|gitlab|gitea|none) [github]: '
  read -r _rh || _rh=""; [ -z "$_rh" ] && _rh="github"

  printf 'Block severity (low|medium|high|critical) [high]: '
  read -r _bs || _bs=""; [ -z "$_bs" ] && _bs="high"

  printf 'Builder CLI command [claude]: '
  read -r _bc || _bc=""; [ -z "$_bc" ] && _bc="claude"

  if [ "$_vm" = "2" ]; then
    printf 'Reviewer CLI command [codex]: '
    read -r _rc || _rc=""; [ -z "$_rc" ] && _rc="codex"
  else
    _rc="$_bc"
  fi

  awk -v vm="$_vm" -v db="$_db" -v rh="$_rh" -v bs="$_bs" -v bc="$_bc" -v rc="$_rc" '
    /^CLAGENTIC_DEFAULT_BRANCH=/    { print "CLAGENTIC_DEFAULT_BRANCH=" db; next }
    /^CLAGENTIC_REPO_HOST=/         { print "CLAGENTIC_REPO_HOST=" rh; next }
    /^CLAGENTIC_BLOCK_SEVERITY=/    { print "CLAGENTIC_BLOCK_SEVERITY=" bs; next }
    /^CLAGENTIC_BUILDER_CMD=/       { print "CLAGENTIC_BUILDER_CMD=" bc; next }
    /^CLAGENTIC_REVIEWER_CMD=/      { print "CLAGENTIC_REVIEWER_CMD=" rc; next }
    /^CLAGENTIC_(AUDITOR|GATE)_CMD=/ { print $0; next }
    { print }
  ' "$GLOBAL_CONFIG" > "$GLOBAL_CONFIG.tmp"
  mv "$GLOBAL_CONFIG.tmp" "$GLOBAL_CONFIG"
  chmod 600 "$GLOBAL_CONFIG"

  if [ "$vm" = "1" ] || [ "$_bc" = "$_rc" ]; then
    warn "Builder and Reviewer both set to '$_bc'. Cross-vendor review surfaces blind spots that same-vendor review shares."
  fi
}

_ensure_local_bin() {
  if [ ! -d "$LOCAL_BIN" ]; then
    mkdir -p "$LOCAL_BIN" \
      || { warn "cannot create $LOCAL_BIN"; return 1; }
  fi
  # Warn if LOCAL_BIN is not on PATH.
  case ":$PATH:" in
    *":$LOCAL_BIN:"*) : ;;
    *)
      warn "$LOCAL_BIN is not on \$PATH"
      warn "Add this line to your shell profile (~/.bashrc, ~/.zshrc, ~/.profile):"
      warn '  export PATH="$HOME/.local/bin:$PATH"'
      ;;
  esac
}

_install_symlink() {
  _CLI_TARGET="$CLAGENTIC_HOME/bin/clagentic-lite"
  if [ ! -f "$_CLI_TARGET" ]; then
    warn "bin/clagentic-lite not found at $_CLI_TARGET — cannot create symlink"
    return 1
  fi
  chmod +x "$_CLI_TARGET"

  if [ -e "$CLI_SYMLINK" ] && [ ! -L "$CLI_SYMLINK" ]; then
    warn "$CLI_SYMLINK exists and is a regular file, not a symlink — refusing to overwrite"
    warn "Remove it manually then re-run \`clagentic-lite init\`"
    return 1
  fi
  # Remove existing symlink (may point to old path) and recreate.
  rm -f "$CLI_SYMLINK"
  ln -s "$_CLI_TARGET" "$CLI_SYMLINK"
  say "symlinked: $CLI_SYMLINK -> $_CLI_TARGET"
}

# ---------------------------------------------------------------- enroll

cmd_enroll() {
  ENROLL_SELF=0
  ENROLL_FORCE=0
  _paths=""

  for _a in "$@"; do
    case "$_a" in
      --self)  ENROLL_SELF=1 ;;
      --force) ENROLL_FORCE=1 ;;
      -*)      warn "unknown flag: $_a" ;;
      *)       _paths="$_paths $_a" ;;
    esac
  done
  export ENROLL_FORCE

  # Default to $PWD if no paths given.
  [ -z "$_paths" ] && _paths="$PWD"

  for _raw_path in $_paths; do
    _enroll_one "$(ds_realpath "$_raw_path")"
  done
}


# _register_wrapper_repo WRAPPER_DIR REPO_PATH
# Appends REPO_PATH to WRAPPER_DIR/.clagentic-project, stamps wrapper CLAUDE.md,
# then enrolls the repo.
_register_wrapper_repo() {
  _rwr_wrapper="$1"
  _rwr_repo="$2"
  printf '%s\n' "$_rwr_repo" >> "$_rwr_wrapper/.clagentic-project"
  _stamp_wrapper_claude_md "$_rwr_wrapper" "$_rwr_repo"
  _enroll_one "$_rwr_repo"
}

_enroll_one() {
  _ep="$1"
  # _ep_orig tracks the original argument so we can write .clagentic-project
  # to the wrapper directory rather than to the enrolled repo.
  _ep_orig="$_ep"

  # Verify it's a git repo. If not, offer wrapper detection (tty only) or
  # fall through to a git init offer.
  if ! git -C "$_ep" rev-parse --git-dir >/dev/null 2>&1; then
    if [ -t 0 ]; then
      # Scan for nested git repos up to 3 levels deep.
      _nested_raw=$(find "$_ep" -maxdepth 3 -name .git -type d 2>/dev/null)
      _nested_count=0
      _nested_list=""
      for _ng in $_nested_raw; do
        # Strip trailing /.git to get repo path.
        _nr="${_ng%/.git}"
        _nested_count=$((_nested_count+1))
        _nested_list="$_nested_list $_nr"
      done

      if [ "$_nested_count" -gt 0 ]; then
        printf 'enroll: %s is not a git repo — found %d nested repo(s):\n' "$_ep" "$_nested_count"
        _i=0
        for _nr in $_nested_list; do
          _i=$((_i+1))
          printf '  %d) %s\n' "$_i" "$_nr"
        done

        if [ "$_nested_count" -eq 1 ]; then
          # Single nested repo: simple Y/n/q prompt.
          _single_repo=""
          for _nr in $_nested_list; do _single_repo="$_nr"; done
          printf 'Enroll it? [Y/n/q(uit)]: '
          read -r _reply || _reply=""
          [ -z "$_reply" ] && _reply="Y"
          case "$_reply" in
            q|Q)
              return 1
              ;;
            n|N)
              # Fall through to git init offer below.
              _nested_count=0
              ;;
            *)
              # Y or blank: enroll the nested repo.
              _register_wrapper_repo "$_ep_orig" "$_single_repo"
              return $?
              ;;
          esac
        else
          # Multiple nested repos: A / # / n / q prompt.
          printf 'Enroll: [A]ll / [#] pick one / [n]one (git init instead) / [q]uit: '
          read -r _reply || _reply=""
          case "$_reply" in
            q|Q)
              return 1
              ;;
            n|N)
              # Fall through to git init offer below.
              _nested_count=0
              ;;
            a|A)
              # Enroll all nested repos.
              for _nr in $_nested_list; do
                _register_wrapper_repo "$_ep_orig" "$_nr"
              done
              return 0
              ;;
            *)
              # Digit: enroll the numbered repo.
              _pick="$_reply"
              _i=0
              _found=""
              for _nr in $_nested_list; do
                _i=$((_i+1))
                if [ "$_i" = "$_pick" ]; then
                  _found="$_nr"
                fi
              done
              if [ -n "$_found" ]; then
                _register_wrapper_repo "$_ep_orig" "$_found"
                return $?
              else
                warn "enroll: invalid selection '$_reply' — skipping"
                return 1
              fi
              ;;
          esac
        fi
      fi

      # git init offer: reached when no nested repos found, or user chose n.
      printf 'enroll: no git repo found under %s.\n' "$_ep"
      printf 'Initialize a new git repo here with `git init`? [Y/n]: '
      read -r _reply || _reply=""
      [ -z "$_reply" ] && _reply="Y"
      case "$_reply" in
        n|N)
          warn "enroll: skipping — no git repo and user declined git init"
          return 1
          ;;
        *)
          git init "$_ep" || { warn "enroll: git init failed for $_ep"; return 1; }
          # Fall through: _ep is now a git repo; the check below will pass.
          ;;
      esac
    else
      # Non-tty: original behavior.
      warn "enroll: $_ep is not a git repository — skipping"
      return 1
    fi
  fi

  _canon=$(ds_realpath "$_ep")
  _home_canon=$(ds_realpath "$CLAGENTIC_HOME")

  # Snake's-head check: refuse to enroll $CLAGENTIC_HOME itself unless --self.
  if [ "$_canon" = "$_home_canon" ] && [ "$ENROLL_SELF" -ne 1 ]; then
    warn "enroll: refusing to enroll \$CLAGENTIC_HOME itself ($_canon)"
    warn "Use --self if you intentionally want the tool to gate itself."
    return 1
  fi

  # Already enrolled check.
  if [ -f "$REGISTRY" ] && grep -qxF "$_canon" "$REGISTRY" 2>/dev/null; then
    if [ "$ENROLL_FORCE" -ne 1 ]; then
      warn "enroll: $_canon is already enrolled (use --force to re-enroll)"
      return 0
    fi
  fi

  # Initialize .clagentic/ DBs in the enrolled repo.
  _dot="$_canon/.clagentic"
  mkdir -p "$_dot" && chmod 755 "$_dot" \
    || { warn "cannot create $_dot"; return 1; }

  CLAGENTIC_PROJECT_ROOT="$_canon" "$CLAGENTIC_HOME/scripts/memory.sh" init
  CLAGENTIC_PROJECT_ROOT="$_canon" "$CLAGENTIC_HOME/scripts/gates.sh" init

  # Stamp hook shims.
  _git_dir=$(git -C "$_canon" rev-parse --git-dir)
  # git rev-parse --git-dir may return a relative path when inside the repo.
  case "$_git_dir" in
    /*) _hooks_dir="$_git_dir/hooks" ;;
    *)  _hooks_dir="$_canon/$_git_dir/hooks" ;;
  esac
  mkdir -p "$_hooks_dir" || true

  stamp_shim pre-commit "$_hooks_dir" || true
  stamp_shim pre-push   "$_hooks_dir" || true

  # Stamp Claude Code integration (.claude/ inside the enrolled repo).
  # settings.json: absolute paths so hook scripts resolve back to CLAGENTIC_HOME.
  # commands/: symlink — pure markdown, no path traversal, stays in sync
  # automatically when the tool updates.
  # agents and skills: installed globally via the clagentic-lite plugin; no per-repo
  # files needed.
  _claude_settings_template="$SHARE_DIR/hook-shims/claude-settings.template"
  if [ -f "$_claude_settings_template" ]; then
    _claude_dir="$_canon/.claude"
    mkdir -p "$_claude_dir" || { warn "cannot create $_claude_dir"; }

    # Generate settings.json with absolute hook paths substituted in.
    _cs_target="$_claude_dir/settings.json"
    if [ -f "$_cs_target" ] && ! grep -q 'managed-by: clagentic' "$_cs_target" 2>/dev/null; then
      if [ "${ENROLL_FORCE:-0}" = "1" ]; then
        warn "overwriting existing non-clagentic .claude/settings.json (--force)"
      else
        warn "existing .claude/settings.json in $_canon is not clagentic-managed — skipping Claude Code wiring (use --force to overwrite)"
        _claude_dir=""
      fi
    fi

    if [ -n "$_claude_dir" ]; then
      sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_claude_settings_template" > "$_cs_target"

      # Symlink commands/ — markdown only, no path traversal.
      ln -sfn "$CLAGENTIC_HOME/.claude/commands" "$_claude_dir/commands"

      # Skills (/infosec-rt, /eng-consult) are installed globally via the
      # clagentic-lite plugin (claude plugin install, run during init).
      # No per-repo symlink needed — Claude Code discovers them from the plugin.

      # Agent files are installed globally via the clagentic-lite plugin
      # (claude plugin install, run during init). No per-repo copy needed.

      say "wired Claude Code hooks: $_claude_dir"
    fi
  else
    warn "claude-settings.template missing — skipping Claude Code hook wiring"
  fi

  # Stamp CLAUDE.md in the enrolled repo root with a thin enrollment notice.
  # The notice is unconditionally true: it describes enrollment support without
  # binding rules that assume clagentic-lite is installed for all teammates.
  # CLAUDE.md is NOT gitignored — it's a legitimate project file the user may
  # extend. The notice block is ~5 lines; user content below it is preserved on
  # restamp (see _restamp_repo_artifacts).
  _claude_md_template="$SHARE_DIR/hook-shims/CLAUDE.md.template"
  _claude_md_target="$_canon/CLAUDE.md"
  if [ -f "$_claude_md_template" ]; then
    if [ -f "$_claude_md_target" ] && ! grep -q 'managed-by: clagentic' "$_claude_md_target" 2>/dev/null; then
      if [ "${ENROLL_FORCE:-0}" = "1" ]; then
        warn "overwriting existing non-clagentic CLAUDE.md (--force)"
      else
        warn "existing CLAUDE.md in $_canon is not clagentic-managed — skipping (use --force to overwrite)"
        _claude_md_template=""
      fi
    fi
    if [ -n "$_claude_md_template" ]; then
      cp "$_claude_md_template" "$_claude_md_target"
      say "stamped CLAUDE.md: $_claude_md_target"
    fi
  else
    warn "CLAUDE.md.template missing — skipping enrollment notice stamp"
  fi

  # Stamp .clagentic/builder-contract.md — full builder rules, agent table,
  # slash commands, hooks, and gate reference. Gitignored (local machine only).
  # Injected by session-start.sh at session open so Claude Code gets the full
  # contract every session without it living in a committed file.
  _contract_template="$SHARE_DIR/hook-shims/builder-contract.template"
  _contract_target="$_canon/.clagentic/builder-contract.md"
  _default_branch="${CLAGENTIC_DEFAULT_BRANCH:-main}"
  if [ -f "$_contract_template" ]; then
    mkdir -p "$_canon/.clagentic" 2>/dev/null || true
    sed -e "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" \
        -e "s|__CLAGENTIC_DEFAULT_BRANCH__|$_default_branch|g" \
        "$_contract_template" > "$_contract_target"
    say "stamped builder contract: $_contract_target"
  else
    warn "builder-contract.template missing — skipping builder contract stamp"
  fi

  # Add .claude/ and .clagentic/ to the project's .gitignore so the generated
  # wiring and local machine state are not accidentally committed.
  _gitignore="$_canon/.gitignore"
  if [ -f "$_gitignore" ]; then
    if ! grep -qxF '.claude/' "$_gitignore" 2>/dev/null; then
      printf '.claude/\n' >> "$_gitignore"
      say "added .claude/ to $_gitignore"
    fi
    if ! grep -qxF '.clagentic/' "$_gitignore" 2>/dev/null; then
      printf '.clagentic/\n' >> "$_gitignore"
      say "added .clagentic/ to $_gitignore"
    fi
  else
    printf '.claude/\n.clagentic/\n' > "$_gitignore"
    say "created $_gitignore with .claude/ and .clagentic/"
  fi

  # Register.
  _reg_dir="$(dirname "$REGISTRY")"
  mkdir -p "$_reg_dir" || true

  # Remove any stale entry for this path before appending.
  if [ -f "$REGISTRY" ]; then
    grep -vxF "$_canon" "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true
    mv "$REGISTRY.tmp" "$REGISTRY"
  fi
  printf '%s\n' "$_canon" >> "$REGISTRY"

  say "enrolled: $_canon"
}

# ---------------------------------------------------------------- unenroll

cmd_unenroll() {
  UNENROLL_PURGE=0
  _path="$PWD"

  for _a in "$@"; do
    case "$_a" in
      --purge) UNENROLL_PURGE=1 ;;
      -*)      warn "unknown flag: $_a" ;;
      *)       _path="$_a" ;;
    esac
  done

  _canon=$(ds_realpath "$_path")

  if ! git -C "$_canon" rev-parse --git-dir >/dev/null 2>&1; then
    warn "unenroll: $_canon is not a git repository"
    return 1
  fi

  _git_dir=$(git -C "$_canon" rev-parse --git-dir)
  case "$_git_dir" in
    /*) _hooks_dir="$_git_dir/hooks" ;;
    *)  _hooks_dir="$_canon/$_git_dir/hooks" ;;
  esac

  # Remove only clagentic-owned hooks.
  for _hook in pre-commit pre-push; do
    _hf="$_hooks_dir/$_hook"
    if [ -f "$_hf" ]; then
      if grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
        rm -f "$_hf"
        say "removed hook: $_hf"
      else
        say "skipping non-clagentic hook: $_hf"
      fi
    fi
  done

  # Remove clagentic-owned Claude Code integration (.claude/).
  _cs_file="$_canon/.claude/settings.json"
  if [ -f "$_cs_file" ] && grep -q 'managed-by: clagentic' "$_cs_file" 2>/dev/null; then
    rm -f "$_cs_file"
    # Remove symlink we own for commands/.
    rm -f "$_canon/.claude/commands"
    # Agents and skills are installed globally via the plugin — no per-repo files to remove.
    # Remove .claude/ dir only if now empty.
    rmdir "$_canon/.claude" 2>/dev/null || true
    say "removed Claude Code wiring: $_canon/.claude"
  fi

  # Remove clagentic-managed CLAUDE.md.
  _cm_file="$_canon/CLAUDE.md"
  if [ -f "$_cm_file" ] && grep -q 'managed-by: clagentic' "$_cm_file" 2>/dev/null; then
    rm -f "$_cm_file"
    say "removed CLAUDE.md: $_cm_file"
  fi

  # Deregister.
  if [ -f "$REGISTRY" ]; then
    grep -vxF "$_canon" "$REGISTRY" > "$REGISTRY.tmp" 2>/dev/null || true
    mv "$REGISTRY.tmp" "$REGISTRY"
  fi

  # Purge .clagentic/ if requested.
  # Note: .clagentic/ contains audit.db, memory.db, and builder-contract.md —
  # all local machine state (gitignored). The --purge flag removes this data.
  # Without --purge, .clagentic/ is left in place (data is preserved).
  if [ "$UNENROLL_PURGE" -eq 1 ]; then
    _dot="$_canon/.clagentic"
    if [ -d "$_dot" ]; then
      rm -rf -- "$_dot"
      say "purged: $_dot"
    fi
  else
    say "note: .clagentic/ left in place (use --purge to remove audit.db, memory.db, and builder-contract.md)"
  fi

  say "unenrolled: $_canon"
}

# ---------------------------------------------------------------- list

cmd_list() {
  if [ ! -f "$REGISTRY" ]; then
    say "no enrolled repos (registry not found at $REGISTRY)"
    return 0
  fi

  _HR='------------------------------------------------------------------------------------------'
  printf '%-50s  %-24s  %s\n' "PATH" "LAST GATE RUN" "STATUS"
  printf '%s\n' "$_HR"

  while IFS= read -r _rpath; do
    [ -z "$_rpath" ] && continue

    # Determine status.
    _status="ok"
    if [ ! -d "$_rpath" ]; then
      _status="stale"
    elif ! git -C "$_rpath" rev-parse --git-dir >/dev/null 2>&1; then
      _status="not-a-repo"
    else
      _git_dir=$(git -C "$_rpath" rev-parse --git-dir)
      case "$_git_dir" in
        /*) _hooks_dir="$_git_dir/hooks" ;;
        *)  _hooks_dir="$_rpath/$_git_dir/hooks" ;;
      esac
      # Check both shims are present and clagentic-owned.
      for _hook in pre-commit pre-push; do
        _hf="$_hooks_dir/$_hook"
        if [ ! -f "$_hf" ]; then
          _status="hooks missing"
        elif ! grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
          _status="hooks replaced"
        fi
      done
      # Check tool still exists at the baked-in path.
      if [ -f "$_hooks_dir/pre-commit" ]; then
        _baked=$(grep -E '__CLAGENTIC_HOME__|CLAGENTIC_HOME:=' "$_hooks_dir/pre-commit" 2>/dev/null | head -1)
        if [ -z "$_baked" ] && ! grep -q "$CLAGENTIC_HOME" "$_hooks_dir/pre-commit" 2>/dev/null; then
          _status="tool missing"
        fi
      fi
    fi

    # Last gate run from audit.db.
    _db="$_rpath/.clagentic/audit.db"
    _last_run=""
    if [ -f "$_db" ]; then
      _last_run=$(sqlite3 "$_db" "SELECT MAX(ts) FROM gate_runs;" 2>/dev/null || true)
    fi
    [ -z "$_last_run" ] && _last_run="(never)"

    printf '%-50s  %-24s  %s\n' "$_rpath" "$_last_run" "$_status"
  done < "$REGISTRY"
}

# ---------------------------------------------------------------- doctor

cmd_doctor() {
  _ok=0; _fail=0
  _ok()   { printf '  OK   %s\n' "$*"; _ok=$((_ok+1)); }
  _fail() { printf '  FAIL %s\n' "$*" 1>&2; _fail=$((_fail+1)); }

  printf '\n== clagentic-lite doctor ==\n\n'

  # 1. CLAGENTIC_HOME exists and is a valid checkout.
  if [ -f "$CLAGENTIC_HOME/scripts/gates.sh" ]; then
    _ok "CLAGENTIC_HOME=$CLAGENTIC_HOME (valid checkout)"
  else
    _fail "CLAGENTIC_HOME=$CLAGENTIC_HOME (gates.sh missing — is this a clagentic-lite checkout?)"
  fi

  # 2. Symlink correct.
  if [ -L "$CLI_SYMLINK" ]; then
    _sym_target=$(readlink "$CLI_SYMLINK" 2>/dev/null || true)
    if [ "$_sym_target" = "$CLAGENTIC_HOME/bin/clagentic-lite" ]; then
      _ok "$CLI_SYMLINK -> $CLAGENTIC_HOME/bin/clagentic-lite"
    else
      _fail "$CLI_SYMLINK points to $_sym_target (expected $CLAGENTIC_HOME/bin/clagentic-lite)"
    fi
  elif [ -e "$CLI_SYMLINK" ]; then
    _fail "$CLI_SYMLINK exists but is not a symlink"
  else
    _fail "$CLI_SYMLINK missing — run \`clagentic-lite init\`"
  fi

  # 3. LOCAL_BIN on PATH.
  case ":$PATH:" in
    *":$LOCAL_BIN:"*) _ok "$LOCAL_BIN is on \$PATH" ;;
    *) _fail "$LOCAL_BIN is NOT on \$PATH — add: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
  esac

  # 4. Required prereqs.
  printf '\nprerequisites:\n'
  for _tool in sqlite3 git; do
    if command -v "$_tool" >/dev/null 2>&1; then
      _ok "$_tool found"
    else
      _fail "$_tool missing"
    fi
  done
  if command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1; then
    _ok "JSON validator (jq or python3) found"
  else
    _fail "JSON validator missing (need jq or python3)"
  fi
  if command -v python3 >/dev/null 2>&1; then
    _ok "python3 found (W-002 path normalization: full)"
  else
    printf "  WARN python3 not found — W-002 uses POSIX fallback normalization (symlink targets not resolved)\n"
  fi

  # 5. Security tool status (advisory — missing is a warn, not a fail).
  # Tool names come from CLAGENTIC_SECURITY_TOOLS (top of file), same source
  # _run_prereq_checks uses — they cannot drift apart.
  printf '\nsecurity tools:\n'
  for _stool in $CLAGENTIC_SECURITY_TOOLS; do
    if command -v "$_stool" >/dev/null 2>&1; then
      _ok "$_stool found"
    else
      printf '  WARN %s not installed (security gate will block unless ALLOW_MISSING set)\n' "$_stool"
    fi
  done

  # 6. Registry + enrolled repos.
  printf '\nenrolled repos:\n'
  if [ ! -f "$REGISTRY" ]; then
    printf '  (no registry at %s)\n' "$REGISTRY"
  else
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      if [ ! -d "$_rpath" ]; then
        _fail "registered repo no longer exists: $_rpath"
        continue
      fi
      _git_dir=$(git -C "$_rpath" rev-parse --git-dir 2>/dev/null || true)
      if [ -z "$_git_dir" ]; then
        _fail "$_rpath: not a git repo"
        continue
      fi
      case "$_git_dir" in
        /*) _hd="$_git_dir/hooks" ;;
        *)  _hd="$_rpath/$_git_dir/hooks" ;;
      esac
      for _hook in pre-commit pre-push; do
        _hf="$_hd/$_hook"
        if [ ! -f "$_hf" ]; then
          _fail "$_rpath: .git/hooks/$_hook missing"
        elif ! grep -q 'managed-by: clagentic' "$_hf" 2>/dev/null; then
          _fail "$_rpath: .git/hooks/$_hook not clagentic-managed"
        elif ! grep -q "$CLAGENTIC_HOME" "$_hf" 2>/dev/null; then
          _fail "$_rpath: .git/hooks/$_hook points to different CLAGENTIC_HOME (run \`clagentic-lite update\`)"
        else
          _ok "$_rpath: .git/hooks/$_hook OK"
        fi
      done
      # Check CLAUDE.md enrollment notice in enrolled repo.
      _cm_file="$_rpath/CLAUDE.md"
      if [ ! -f "$_cm_file" ]; then
        printf '  WARN  %s: CLAUDE.md missing (run `clagentic-lite enroll --force`)\n' "$_rpath"
      elif ! grep -q 'managed-by: clagentic' "$_cm_file" 2>/dev/null; then
        printf '  WARN  %s: CLAUDE.md not clagentic-managed (manual CLAUDE.md?)\n' "$_rpath"
      else
        # Check for new thin-notice marker first; fall back to legacy marker.
        _repo_notice_ver=$(claude_notice_version "$_cm_file")
        _repo_old_ver=$(claude_md_version "$_cm_file")
        if [ -n "$_repo_notice_ver" ]; then
          if [ "$_repo_notice_ver" != "$CLAUDE_NOTICE_VERSION" ]; then
            # Notice drift is low-risk — INFO not FAIL.
            printf '  INFO  %s: CLAUDE.md notice version %s (current: %s) — run `clagentic-lite update` to refresh\n' \
              "$_rpath" "$_repo_notice_ver" "$CLAUDE_NOTICE_VERSION"
          else
            _ok "$_rpath: CLAUDE.md notice version $CLAUDE_NOTICE_VERSION OK"
          fi
        elif [ -n "$_repo_old_ver" ]; then
          # Old fat CLAUDE.md — warn; update will migrate to thin notice.
          printf '  WARN  %s: CLAUDE.md uses old format (clagentic-claude-md-version: %s) — run `clagentic-lite update` to migrate to thin notice\n' \
            "$_rpath" "$_repo_old_ver"
        else
          printf '  WARN  %s: CLAUDE.md has managed-by marker but no version tag — run `clagentic-lite update --restamp`\n' "$_rpath"
        fi
      fi
      # Check builder-contract.md (local, gitignored).
      _contract_file="$_rpath/.clagentic/builder-contract.md"
      if [ ! -f "$_contract_file" ]; then
        printf '  WARN  %s: .clagentic/builder-contract.md missing — sessions lack full builder context (run `clagentic-lite enroll --force`)\n' "$_rpath"
      elif ! grep -q 'managed-by: clagentic' "$_contract_file" 2>/dev/null; then
        printf '  WARN  %s: .clagentic/builder-contract.md not clagentic-managed\n' "$_rpath"
      else
        _repo_contract_ver=$(claude_contract_version "$_contract_file")
        if [ "$_repo_contract_ver" != "$CLAUDE_CONTRACT_VERSION" ]; then
          # Auto-restamp contract on doctor run — it's gitignored and cheap.
          _ra_default_branch="${CLAGENTIC_DEFAULT_BRANCH:-main}"
          _ra_ct="$SHARE_DIR/hook-shims/builder-contract.template"
          if [ -f "$_ra_ct" ]; then
            sed -e "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" \
                -e "s|__CLAGENTIC_DEFAULT_BRANCH__|$_ra_default_branch|g" \
                "$_ra_ct" > "$_contract_file"
            _ok "$_rpath: .clagentic/builder-contract.md auto-restamped to $CLAUDE_CONTRACT_VERSION"
          else
            printf '  WARN  %s: .clagentic/builder-contract.md version %s (current: %s) — run `clagentic-lite update`\n' \
              "$_rpath" "$_repo_contract_ver" "$CLAUDE_CONTRACT_VERSION"
          fi
        else
          _ok "$_rpath: .clagentic/builder-contract.md version $CLAUDE_CONTRACT_VERSION OK"
        fi
      fi
      # Check for stale command docs removed in v1.1.0.
      for _stale_cmd in ship.md review.md; do
        _stale_path="$_rpath/.claude/commands/$_stale_cmd"
        # Commands dir is a symlink to central install — stale docs only exist
        # when the symlink target is an old checkout that still has them.
        if [ -f "$_stale_path" ]; then
          _fail "$_rpath: stale command doc .claude/commands/$_stale_cmd found — run \`clagentic-lite update --restamp\`"
        fi
      done
    done < "$REGISTRY"
  fi


  # 7. Wrapper .clagentic-project pointer files
  printf '\nwrapper .clagentic-project pointers:\n'
  _wrapper_found=0
  if [ -f "$REGISTRY" ]; then
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      _parent=$(dirname "$_rpath")
      _ptr="$_parent/.clagentic-project"
      [ -f "$_ptr" ] || continue
      _wrapper_found=1
      printf '  checking %s\n' "$_ptr"
      while IFS= read -r _ppath; do
        [ -z "$_ppath" ] && continue
        if [ ! -d "$_ppath" ]; then
          _fail "stale pointer in $_ptr: '$_ppath' no longer exists"
        elif ! git -C "$_ppath" rev-parse --git-dir >/dev/null 2>&1; then
          _fail "stale pointer in $_ptr: '$_ppath' is not a git repo"
        elif ! grep -qxF "$_ppath" "$REGISTRY" 2>/dev/null; then
          printf '  WARN  pointer entry %s is not in registry (re-run enroll?)\n' "$_ppath"
        else
          _ok "wrapper pointer: $_ppath"
        fi
      done < "$_ptr"
    done < "$REGISTRY"
  fi
  [ "$_wrapper_found" -eq 0 ] && printf '  (no wrapper .clagentic-project files found)\n'

  # 8. LLM CLI auth probes.
  # Checks that each configured primary CLI is present AND can make a real
  # call. A CLI on PATH that fails auth silently degrades to the chain
  # fallback — this surfaces that before it matters in a gate run.
  # The probe uses a minimal prompt ("ping") with a short timeout so doctor
  # doesn't stall on a slow network. Results are WARN (not FAIL) because a
  # missing or unconfigured CLI causes degraded output, not a hard crash.
  printf '\nLLM CLI auth probes:\n'
  _llm_probe_timeout=10
  # Collect the unique set of primary CLIs across all roles.
  _probed_clis=""
  for _role_pfx in BUILDER REVIEWER AUDITOR GATE SUMMARIZER; do
    _pcmd=$(eval "printf '%s' \"\${CLAGENTIC_${_role_pfx}_CMD:-}\"")
    [ -z "$_pcmd" ] && continue
    # Skip duplicates.
    case " $_probed_clis " in
      *" $_pcmd "*) continue ;;
    esac
    _probed_clis="$_probed_clis $_pcmd"

    if ! command -v "$_pcmd" >/dev/null 2>&1; then
      printf '  WARN %s: not on PATH (roles: %s)\n' "$_pcmd" "$_role_pfx"
      continue
    fi

    # CLI is present — probe auth with a minimal call.
    _probe_out=$(mktemp -t clagentic-doctor-probe.XXXXXX)
    _probe_err=$(mktemp -t clagentic-doctor-probe-err.XXXXXX)
    _probe_ok=0
    case "$_pcmd" in
      claude)
        # claude --print "ping" — succeeds on any auth path (OAuth or API key).
        # CLAGENTIC_DISABLE_RECALL=1 avoids triggering session-start hooks.
        CLAGENTIC_DISABLE_RECALL=1 \
          $DS_TIMEOUT_CMD "$_llm_probe_timeout" claude --print "ping" \
          > "$_probe_out" 2> "$_probe_err" && _probe_ok=1 || true
        ;;
      codex)
        # Mirror the production invoke_codex path: use -o to capture the
        # response (stdout is spinner/progress noise). The prior approach
        # captured stdout, which exercises a different output channel than
        # every real gate call — causing false PASS or false FAIL.
        _probe_o=$(mktemp -t clagentic-doctor-codex-o.XXXXXX)
        $DS_TIMEOUT_CMD "$_llm_probe_timeout" codex exec --skip-git-repo-check \
          --color never -o "$_probe_o" "ping" \
          > "$_probe_err" 2>&1 && _probe_ok=1 || true
        # Strip ANSI from -o file, mirroring invoke_codex's post-processing.
        if [ -s "$_probe_o" ]; then
          sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$_probe_o" > "$_probe_out" 2>/dev/null \
            || cp "$_probe_o" "$_probe_out"
        fi
        rm -f "$_probe_o"
        ;;
      *)
        # Generic: try `-p ping`.
        $DS_TIMEOUT_CMD "$_llm_probe_timeout" "$_pcmd" -p "ping" \
          > "$_probe_out" 2> "$_probe_err" && _probe_ok=1 || true
        ;;
    esac

    if [ "$_probe_ok" = "1" ] && [ -s "$_probe_out" ]; then
      _ok "$_pcmd: auth probe passed"
    else
      # Strip ANSI from error output before showing it.
      _probe_hint=$(sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$_probe_err" 2>/dev/null \
        | grep -v '^[[:space:]]*$' | head -1 | cut -c1-120) || \
        _probe_hint=$(head -1 "$_probe_err" 2>/dev/null | cut -c1-120)
      [ -z "$_probe_hint" ] && _probe_hint="no output (auth expired or model unavailable?)"
      printf '  WARN %s: auth probe failed — %s\n' "$_pcmd" "$_probe_hint"
    fi
    rm -f "$_probe_out" "$_probe_err"
  done
  [ -z "$_probed_clis" ] && printf '  (no LLM CLIs configured — set CLAGENTIC_*_CMD in config)\n'

  # 9. Cross-vendor invariant check.
  # The whole point of clagentic-lite is that Builder and Reviewer are different
  # CLIs so they don't share blind spots. Warn (not fail) when they match —
  # a single-CLI setup still works, but the cross-vendor property is gone.
  printf '\ncross-vendor check:\n'
  _builder_cmd="${CLAGENTIC_BUILDER_CMD:-}"
  _reviewer_cmd="${CLAGENTIC_REVIEWER_CMD:-}"
  if [ -z "$_builder_cmd" ] || [ -z "$_reviewer_cmd" ]; then
    printf '  (Builder or Reviewer CMD not configured — skipping cross-vendor check)\n'
  elif [ "$_builder_cmd" = "$_reviewer_cmd" ]; then
    printf '  WARN Builder and Reviewer both use "%s" — cross-vendor review is disabled.\n' "$_builder_cmd"
    printf '       Set CLAGENTIC_REVIEWER_CMD to a different CLI (e.g. codex vs claude).\n'
    printf '       Or set CLAGENTIC_REVIEWER_REQUIRED=1 to make same-vendor fallback a hard failure.\n'
    printf '       See docs/DESIGN.md §"The three roles" for rationale.\n'
  else
    _ok "Builder=$_builder_cmd / Reviewer=$_reviewer_cmd (cross-vendor OK)"
  fi

  # 10. Memory tunables.
  printf '\nmemory tunables:\n'
  _ok "CLAGENTIC_RECALL_LIMIT=${CLAGENTIC_RECALL_LIMIT:-5 (default)}"
  _ok "CLAGENTIC_RECALL_MAX_CHARS=${CLAGENTIC_RECALL_MAX_CHARS:-1500 (default)}"
  _ok "CLAGENTIC_MEMORY_MAX_ROWS=${CLAGENTIC_MEMORY_MAX_ROWS:-5000 (default)}"

  printf '\n== doctor summary: %s OK, %s FAIL ==\n\n' "$_ok" "$_fail"
  [ "$_fail" -eq 0 ]
}

# ---------------------------------------------------------------- update

# _restamp_notice_block FILE TEMPLATE
# Replace the clagentic-managed notice block at the top of FILE with the
# contents of TEMPLATE, preserving any user content that follows it.
#
# Boundary detection (in priority order):
#   1. Closing sentinel "<!-- /clagentic-notice -->" in the first 20 lines —
#      authoritative end-of-block marker present in v2+ templates.
#   2. File is short (< v1 block length) — replace whole file; no user content.
#   3. v1 fallback: no sentinel found. Use the fixed v1 block length (8 lines)
#      as the split boundary. v1 block was exactly 8 lines (the current template
#      minus the sentinel line). User content starts at line 9.
#      IMPORTANT: do not substitute _rnb_tmpl_lines here — the current template
#      is 9 lines (v2), but the installed file is 8-line v1. Using the current
#      template length is off by one and silently drops the first user line.
#
# V1_BLOCK_LINES is the fixed line count of the CLAUDE.md.template at v1.
# It must not be changed. If the template grows, bump CLAUDE_NOTICE_VERSION and
# add a new sentinel-based path; never change this constant.
_RNB_V1_BLOCK_LINES=8
_restamp_notice_block() {
  _rnb_file="$1"
  _rnb_template="$2"
  _rnb_total=$(wc -l < "$_rnb_file" 2>/dev/null || echo 0)

  # Short path: file has fewer lines than the v1 block — nothing follows the
  # managed block regardless of version.
  if [ "$_rnb_total" -lt "$_RNB_V1_BLOCK_LINES" ]; then
    cp "$_rnb_template" "$_rnb_file"
    return 0
  fi

  # Find the closing sentinel "<!-- /clagentic-notice -->" in the first 20 lines.
  _rnb_sentinel_line=0
  _rnb_lineno=0
  while IFS= read -r _rnb_line; do
    _rnb_lineno=$((_rnb_lineno+1))
    [ "$_rnb_lineno" -gt 20 ] && break
    case "$_rnb_line" in
      '<!-- /clagentic-notice -->'*) _rnb_sentinel_line="$_rnb_lineno"; break ;;
    esac
  done < "$_rnb_file"

  if [ "$_rnb_sentinel_line" -eq 0 ]; then
    # No sentinel — v1 install. Split at the fixed v1 block boundary.
    # User content starts at line _RNB_V1_BLOCK_LINES + 1 = 9.
    _rnb_user_start=$((_RNB_V1_BLOCK_LINES + 1))
    _rnb_user=""
    if [ "$_rnb_user_start" -le "$_rnb_total" ]; then
      _rnb_user=$(tail -n "+${_rnb_user_start}" "$_rnb_file" 2>/dev/null || true)
    fi
    if [ -n "$_rnb_user" ]; then
      {
        cat "$_rnb_template"
        printf '%s\n' "$_rnb_user"
      } > "$_rnb_file"
    else
      cp "$_rnb_template" "$_rnb_file"
    fi
    return 0
  fi

  # Sentinel found — split at sentinel line; user content follows.
  _rnb_user_start=$((_rnb_sentinel_line+1))
  _rnb_user=""
  if [ "$_rnb_user_start" -le "$_rnb_total" ]; then
    _rnb_user=$(tail -n "+${_rnb_user_start}" "$_rnb_file" 2>/dev/null || true)
  fi

  # Write: notice block from template (includes sentinel), then user content.
  if [ -n "$_rnb_user" ]; then
    {
      cat "$_rnb_template"
      printf '%s\n' "$_rnb_user"
    } > "$_rnb_file"
  else
    cp "$_rnb_template" "$_rnb_file"
  fi
  return 0
}

# _restamp_repo_artifacts PATH LABEL
# Re-stamp the enrollment notice in CLAUDE.md, builder-contract.md,
# .claude/settings.json, and wrapper CLAUDE.md for PATH.
# LABEL is appended to each say message (e.g. "" for version-mismatch path,
# " (--restamp)" for the force pass) so callers can distinguish log lines.
# Prints the number of artifacts written to stdout; caller adds to _restamped.
# Version checking is the caller's responsibility — this function always writes.
_restamp_repo_artifacts() {
  _ra_path="$1"
  _ra_label="$2"
  _ra_count=0

  # Re-stamp CLAUDE.md notice block only, preserving user content below.
  # The committed repo CLAUDE.md is now a thin notice (~7 lines) that is true
  # for any teammate regardless of whether clagentic-lite is installed.
  _ra_cm="$_ra_path/CLAUDE.md"
  if [ -f "$_ra_cm" ] && grep -q 'managed-by: clagentic' "$_ra_cm" 2>/dev/null; then
    _ra_cm_template="$SHARE_DIR/hook-shims/CLAUDE.md.template"
    if [ -f "$_ra_cm_template" ]; then
      _restamp_notice_block "$_ra_cm" "$_ra_cm_template"
      say "re-stamped${_ra_label}: $_ra_path/CLAUDE.md" >&2
      _ra_count=$((_ra_count+1))
    fi
  fi

  # Re-stamp .clagentic/builder-contract.md — always a full restamp (gitignored,
  # no user content, local only).
  _ra_contract="$_ra_path/.clagentic/builder-contract.md"
  if [ -f "$_ra_contract" ] && grep -q 'managed-by: clagentic' "$_ra_contract" 2>/dev/null; then
    _ra_contract_template="$SHARE_DIR/hook-shims/builder-contract.template"
    if [ -f "$_ra_contract_template" ]; then
      _ra_default_branch="${CLAGENTIC_DEFAULT_BRANCH:-main}"
      sed -e "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" \
          -e "s|__CLAGENTIC_DEFAULT_BRANCH__|$_ra_default_branch|g" \
          "$_ra_contract_template" > "$_ra_contract"
      say "re-stamped${_ra_label}: $_ra_path/.clagentic/builder-contract.md" >&2
      _ra_count=$((_ra_count+1))
    fi
  fi

  # Re-stamp .claude/settings.json.
  _ra_cs="$_ra_path/.claude/settings.json"
  if [ -f "$_ra_cs" ] && grep -q 'managed-by: clagentic' "$_ra_cs" 2>/dev/null; then
    _ra_cs_template="$SHARE_DIR/hook-shims/claude-settings.template"
    if [ -f "$_ra_cs_template" ]; then
      sed "s|__CLAGENTIC_HOME__|$CLAGENTIC_HOME|g" "$_ra_cs_template" > "$_ra_cs"
      say "re-stamped${_ra_label}: $_ra_path/.claude/settings.json" >&2
      _ra_count=$((_ra_count+1))
    fi
  fi

  # Agent files and skills are installed globally via the clagentic-lite plugin.
  # cmd_update bumps plugin.json version and calls 'claude plugin update'
  # to refresh agents and skills on the user's machine — no per-repo copy to maintain.

  # Re-stamp wrapper CLAUDE.md if the parent dir has a .clagentic-project pointer.
  _ra_wrapper_dir=$(dirname "$_ra_path")
  _ra_wrapper_ptr="$_ra_wrapper_dir/.clagentic-project"
  _ra_wrapper_cm="$_ra_wrapper_dir/CLAUDE.md"
  if [ -f "$_ra_wrapper_ptr" ] && [ -f "$_ra_wrapper_cm" ] && \
     grep -q 'managed-by: clagentic' "$_ra_wrapper_cm" 2>/dev/null; then
    _ra_wcm_template="$SHARE_DIR/hook-shims/CLAUDE.md.wrapper.template"
    if [ -f "$_ra_wcm_template" ]; then
      # Re-build the project table from the pointer file.
      _ra_wcm_repos=$(tr '\n' ' ' < "$_ra_wrapper_ptr" 2>/dev/null || true)
      ENROLL_FORCE=1 _stamp_wrapper_claude_md "$_ra_wrapper_dir" "$_ra_wcm_repos" && {
        say "re-stamped wrapper${_ra_label}: $_ra_wrapper_cm" >&2
        _ra_count=$((_ra_count+1))
      }
    fi
  fi

  printf '%d\n' "$_ra_count"
}

cmd_update() {
  RESTAMP=0
  for _arg in "$@"; do
    case "$_arg" in --restamp) RESTAMP=1 ;; esac
  done

  say "updating clagentic-lite at $CLAGENTIC_HOME..."

  # If CLAGENTIC_HOME has uncommitted changes, prompt before discarding them.
  # Local edits to CLAGENTIC_HOME are tool internals, not user work — but the
  # user should confirm before we silently discard them. On non-tty (CI, scripts),
  # warn and proceed automatically so update remains unattended-safe.
  if ! git -C "$CLAGENTIC_HOME" diff --quiet 2>/dev/null; then
    _dirty=$(git -C "$CLAGENTIC_HOME" diff --name-only 2>/dev/null)
    if [ -t 0 ]; then
      printf '[clagentic-lite] WARN: uncommitted changes in %s:\n' "$CLAGENTIC_HOME" >&2
      printf '%s\n' "$_dirty" | sed 's/^/  /' >&2
      printf 'These changes will be discarded to proceed with update. Continue? [y/N]: '
      read -r _stash_reply || _stash_reply=""
      case "$_stash_reply" in
        y|Y|yes|YES)
          git -C "$CLAGENTIC_HOME" stash push -q -m "clagentic-lite update discard" 2>/dev/null
          git -C "$CLAGENTIC_HOME" stash drop -q 2>/dev/null || true
          ;;
        *)
          die "update cancelled — stash or commit changes in $CLAGENTIC_HOME first"
          ;;
      esac
    else
      # Non-tty (CI, script): warn and proceed, discard changes.
      warn "non-tty: discarding uncommitted changes in $CLAGENTIC_HOME to proceed with update"
      warn "dirty files: $(git -C "$CLAGENTIC_HOME" diff --name-only 2>/dev/null | tr '\n' ' ')"
      git -C "$CLAGENTIC_HOME" stash push -q -m "clagentic-lite update discard" 2>/dev/null
      git -C "$CLAGENTIC_HOME" stash drop -q 2>/dev/null || true
    fi
  fi

  # ff-only pull.
  _pre_pull_sha=$(git -C "$CLAGENTIC_HOME" rev-parse HEAD 2>/dev/null || true)
  if ! git -C "$CLAGENTIC_HOME" pull --ff-only; then
    die "git pull --ff-only failed (non-fast-forward divergence or no upstream)"
  fi
  _post_pull_sha=$(git -C "$CLAGENTIC_HOME" rev-parse HEAD 2>/dev/null || true)

  # Re-exec with the freshly-pulled binary so version constants (CLAUDE_MD_VERSION,
  # CLAUDE_SETTINGS_VERSION, SHIM_VERSION) reflect the new code before the restamp
  # check runs. Without re-exec the variables are baked in at script startup and
  # the restamp comparison uses the pre-pull values — meaning a version bump in the
  # pull is invisible to the running process and enrolled repos are never restamped.
  if [ "$_pre_pull_sha" != "$_post_pull_sha" ]; then
    say "re-executing updated binary to pick up new version constants..."
    exec "$CLAGENTIC_HOME/bin/clagentic-lite" update "$@"
  fi

  # Re-run the same prereq sweep that init runs — pre-PR-#6 this only
  # checked sqlite3 + git, so a clagentic-lite update on a host that had since
  # uninstalled e.g. semgrep would silently leave the gate broken.
  say "checking prerequisites post-update..."
  _run_prereq_checks update

  # Install or update the agent plugin. This runs before the registry check so
  # it works on machines with no enrolled repos (e.g. freshly cloned installs
  # where init was run before the plugin system existed).
  _plugin_json="$CLAGENTIC_HOME/plugins/clagentic-lite/.claude-plugin/plugin.json"
  if [ -f "$_plugin_json" ]; then
    # plugin.json version is bumped by maintainer PRs that change agent or skill files.
    # cmd_update does not touch the version — local bumps drift from upstream
    # and break cache invalidation when the repo ships a real version change.

    if command -v claude >/dev/null 2>&1; then
      # Ensure marketplace is registered (idempotent).
      claude plugin marketplace add "$CLAGENTIC_HOME" --scope user 2>/dev/null || true

      # Migration: uninstall old plugin name (clagentic-lite-agents, pre-v1.2.0) before
      # the exact-match check below. Without this, the old name's presence causes the
      # check to fall through to 'plugin update' which fails because the current name
      # was never installed under the old label.
      if claude plugin list 2>/dev/null | grep -qE '(^|[[:space:]])clagentic-lite-agents(@|[[:space:]]|$)'; then
        say "migrating: removing old plugin name clagentic-lite-agents..."
        claude plugin uninstall "clagentic-lite-agents@clagentic-lite" 2>/dev/null || \
          claude plugin uninstall "clagentic-lite-agents" 2>/dev/null || \
          warn "could not uninstall old plugin clagentic-lite-agents — remove manually: claude plugin uninstall clagentic-lite-agents"
      fi

      # Exact-match check: look for the current plugin name as a whole token.
      # Substring grep would match the old name clagentic-lite-agents (which contains
      # "clagentic-lite" as a prefix) and falsely branch into 'plugin update' even when
      # the current plugin was never installed.
      if claude plugin list 2>/dev/null | grep -qE '(^|[[:space:]])clagentic-lite(@|[[:space:]]|$)'; then
        claude plugin marketplace update clagentic-lite && \
          say "refreshed marketplace: clagentic-lite" || \
          warn "claude plugin marketplace update failed — plugin may be stale"
        claude plugin update "clagentic-lite@clagentic-lite" && \
          say "updated plugin: clagentic-lite" || \
          warn "claude plugin update failed; run: claude plugin update clagentic-lite@clagentic-lite"
      else
        claude plugin install "clagentic-lite@clagentic-lite" && \
          say "installed plugin: clagentic-lite (agents and skills now available globally)" || \
          warn "claude plugin install failed; run: claude plugin install clagentic-lite@clagentic-lite"
      fi
    else
      warn "claude not on PATH — skipping plugin install/update (run manually: claude plugin marketplace add $CLAGENTIC_HOME && claude plugin install clagentic-lite@clagentic-lite)"
    fi
  else
    warn "plugin manifest not found: $_plugin_json — skipping plugin update"
  fi

  # Re-stamp shims in registered repos if the template version changed.
  if [ ! -f "$REGISTRY" ]; then
    say "no enrolled repos to re-stamp"
    return 0
  fi

  _restamped=0
  _would_restamp=0           # set when any shim or artifact is out of version
  _would_restamp_artifacts=0 # set only when a CLAUDE.md/settings artifact is out of version
  while IFS= read -r _rpath; do
    [ -z "$_rpath" ] && continue
    [ -d "$_rpath" ] || continue
    _git_dir=$(git -C "$_rpath" rev-parse --git-dir 2>/dev/null || true)
    [ -z "$_git_dir" ] && continue
    case "$_git_dir" in
      /*) _hd="$_git_dir/hooks" ;;
      *)  _hd="$_rpath/$_git_dir/hooks" ;;
    esac
    for _hook in pre-commit pre-push; do
      _hf="$_hd/$_hook"
      _installed_ver=$(shim_version "$_hf")
      if [ "$_installed_ver" != "$SHIM_VERSION" ]; then
        _would_restamp=1
        ENROLL_FORCE=0 stamp_shim "$_hook" "$_hd" && {
          say "re-stamped: $_rpath .git/hooks/$_hook ($_installed_ver -> $SHIM_VERSION)"
          _restamped=$((_restamped+1))
        }
      fi
    done

    # Re-stamp .claude/settings.json, CLAUDE.md notice, builder-contract.md,
    # and wrapper CLAUDE.md if any version changed.
    # _restamp_repo_artifacts handles all writes; we check versions here to
    # decide whether to call it and to set _would_restamp.
    # Guards mirror the originals: only compare version when the file exists and
    # carries the managed-by marker (or, for wrapper, when the pointer exists).
    _need_restamp=0
    _cs_file="$_rpath/.claude/settings.json"
    if [ -f "$_cs_file" ] && grep -q 'managed-by: clagentic' "$_cs_file" 2>/dev/null; then
      _cs_ver=$(claude_settings_version "$_cs_file")
      [ "$_cs_ver" != "$CLAUDE_SETTINGS_VERSION" ] && _need_restamp=1
    fi
    _cm_file="$_rpath/CLAUDE.md"
    if [ ! -f "$_cm_file" ]; then
      # CLAUDE.md entirely absent — restamp unconditionally.
      _need_restamp=1
    elif ! grep -q 'managed-by: clagentic' "$_cm_file" 2>/dev/null; then
      # managed-by marker stripped (user removed the notice). On a TTY, prompt
      # before re-adding; on non-TTY, warn but do not auto-restamp (user may
      # have intentionally replaced it). --restamp overrides and restores it.
      if [ "$RESTAMP" -eq 1 ]; then
        _need_restamp=1
      elif [ -t 0 ]; then
        printf '[clagentic-lite] WARN: %s/CLAUDE.md enrollment notice is missing or was removed.\n' "$_rpath" >&2
        printf 'Re-add the enrollment notice? [y/N]: '
        read -r _notice_reply || _notice_reply=""
        case "$_notice_reply" in
          y|Y|yes|YES) _need_restamp=1 ;;
          *) warn "$_rpath: skipping CLAUDE.md notice re-add (run \`clagentic-lite update --restamp\` to restore)" ;;
        esac
      else
        warn "$_rpath: CLAUDE.md enrollment notice missing — run \`clagentic-lite update --restamp\` to restore"
      fi
    else
      # Support both old marker (clagentic-claude-md-version) and new notice
      # marker (clagentic-notice-version) so the comparison works during transition.
      _cm_notice_ver=$(claude_notice_version "$_cm_file")
      _cm_old_ver=$(claude_md_version "$_cm_file")
      if [ -n "$_cm_notice_ver" ]; then
        # New-style notice file.
        [ "$_cm_notice_ver" != "$CLAUDE_NOTICE_VERSION" ] && _need_restamp=1
      elif [ -n "$_cm_old_ver" ]; then
        # Old-style fat CLAUDE.md — always restamp to migrate to thin notice.
        _need_restamp=1
      fi
    fi
    _contract_file="$_rpath/.clagentic/builder-contract.md"
    if [ -f "$_contract_file" ] && grep -q 'managed-by: clagentic' "$_contract_file" 2>/dev/null; then
      _contract_ver=$(claude_contract_version "$_contract_file")
      [ "$_contract_ver" != "$CLAUDE_CONTRACT_VERSION" ] && _need_restamp=1
    fi
    _vck_wrapper_dir=$(dirname "$_rpath")
    _vck_wrapper_ptr="$_vck_wrapper_dir/.clagentic-project"
    _vck_wrapper_cm="$_vck_wrapper_dir/CLAUDE.md"
    if [ -f "$_vck_wrapper_ptr" ] && [ -f "$_vck_wrapper_cm" ] && \
       grep -q 'managed-by: clagentic' "$_vck_wrapper_cm" 2>/dev/null; then
      _wcm_ver=$(claude_wrapper_version "$_vck_wrapper_cm")
      [ "$_wcm_ver" != "$CLAUDE_WRAPPER_VERSION" ] && _need_restamp=1
    fi
    if [ "$_need_restamp" -eq 1 ]; then
      _would_restamp=1
      _would_restamp_artifacts=1
      # Only auto-stamp when --restamp was not passed; if it was, the force
      # pass below handles all repos uniformly (avoids double-stamp).
      if [ "$RESTAMP" -eq 0 ]; then
        _n=$(_restamp_repo_artifacts "$_rpath" "")
        _restamped=$((_restamped+_n))
      fi
    fi

  done < "$REGISTRY"

  # Interactive prompt: if no artifact (CLAUDE.md/settings) was out of version
  # and --restamp not passed, offer to re-stamp anyway when running on a tty.
  # Uses _would_restamp_artifacts (not _would_restamp) so a shim-only update
  # does not suppress the prompt for CLAUDE.md/settings artifacts.
  if [ "$_would_restamp_artifacts" -eq 0 ] && [ "$RESTAMP" -eq 0 ] && [ -t 0 ] && [ -f "$REGISTRY" ]; then
    _managed_count=0
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      [ -d "$_rpath" ] || continue
      [ -f "$_rpath/CLAUDE.md" ] && grep -q 'managed-by: clagentic' "$_rpath/CLAUDE.md" 2>/dev/null && \
        _managed_count=$((_managed_count+1))
    done < "$REGISTRY"
    if [ "$_managed_count" -gt 0 ]; then
      printf '[clagentic-lite] All %d enrolled repo(s) already at current artifact versions.\n' "$_managed_count"
      printf 'Re-stamp CLAUDE.md notice, builder-contract.md, settings.json, and wrapper CLAUDE.md anyway? [y/N]: '
      read -r _restamp_reply || _restamp_reply=""
      case "$_restamp_reply" in
        y|Y|yes|YES) RESTAMP=1 ;;
      esac
    fi
  fi

  # --restamp pass: force re-stamp all managed artifacts regardless of version.
  if [ "$RESTAMP" -eq 1 ] && [ -f "$REGISTRY" ]; then
    while IFS= read -r _rpath; do
      [ -z "$_rpath" ] && continue
      [ -d "$_rpath" ] || continue
      _n=$(_restamp_repo_artifacts "$_rpath" " (--restamp)")
      _restamped=$((_restamped+_n))
    done < "$REGISTRY"
  fi

  say "update complete (re-stamped $_restamped artifact(s))"
}

# ---------------------------------------------------------------- show

cmd_show() {
  _show_sub="${1:-}"
  _show_n="${2:-10}"
  # validate _show_n is a positive integer
  case "$_show_n" in
    ''|*[!0-9]*) die "show: N must be a positive integer, got: $_show_n" ;;
  esac

  _show_root="${CLAGENTIC_PROJECT_ROOT:-$PWD}"
  # walk up from _show_root to find a directory containing .clagentic/
  _show_search="$_show_root"
  while [ -n "$_show_search" ] && [ "$_show_search" != "/" ]; do
    if [ -d "$_show_search/.clagentic" ]; then
      _show_root="$_show_search"
      break
    fi
    _show_search="$(dirname "$_show_search")"
  done

  case "$_show_sub" in
    memory)
      _db="$_show_root/.clagentic/memory.db"
      [ -f "$_db" ] || die "show: no memory.db at $_db — is this an enrolled repo?"
      printf '\n=== session memory (last %s) ===\n\n' "$_show_n"
      sqlite3 -separator ' | ' "$_db" \
        "SELECT substr(ts,1,16), source, substr(summary,1,120)
         FROM turns
         ORDER BY CASE source WHEN 'manual' THEN 0 ELSE 1 END, ts DESC
         LIMIT $_show_n;" 2>/dev/null \
        | while IFS= read -r _row; do printf '  %s\n' "$_row"; done
      printf '\n'
      ;;
    gates)
      _db="$_show_root/.clagentic/audit.db"
      [ -f "$_db" ] || die "show: no audit.db at $_db — is this an enrolled repo?"
      printf '\n=== gate runs (last %s) ===\n\n' "$_show_n"
      sqlite3 -separator ' | ' "$_db" \
        "SELECT substr(ts,1,16), gate, outcome, substr(coalesce(details,''),1,80)
         FROM gate_runs
         ORDER BY ts DESC
         LIMIT $_show_n;" 2>/dev/null \
        | while IFS= read -r _row; do printf '  %s\n' "$_row"; done
      printf '\n'
      ;;
    '')
      die "show: subcommand required — use: show memory [N] | show gates [N]"
      ;;
    *)
      die "show: unknown subcommand '$_show_sub' — use: memory | gates"
      ;;
  esac
}

# ---------------------------------------------------------------- export

cmd_export() {
  _export_output=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --output) shift; _export_output="$1" ;;
      *)        _export_output="$1" ;;
    esac
    shift
  done

  _export_root="${CLAGENTIC_PROJECT_ROOT:-$PWD}"
  # walk up from _export_root to find a directory containing .clagentic/
  _export_search="$_export_root"
  while [ -n "$_export_search" ] && [ "$_export_search" != "/" ]; do
    if [ -d "$_export_search/.clagentic" ]; then
      _export_root="$_export_search"
      break
    fi
    _export_search="$(dirname "$_export_search")"
  done

  _mem_db="$_export_root/.clagentic/memory.db"
  _audit_db="$_export_root/.clagentic/audit.db"

  [ -f "$_mem_db" ]   || die "export: no memory.db at $_mem_db — is this an enrolled repo?"
  [ -f "$_audit_db" ] || die "export: no audit.db at $_audit_db — is this an enrolled repo?"

  [ -z "$_export_output" ] && _export_output="$_export_root/.clagentic/report.html"

  # serialize memory rows to JSON via python3
  _mem_json=$(python3 -c "
import sqlite3, json, sys
db = sqlite3.connect(sys.argv[1])
rows = db.execute(
  'SELECT ts, source, summary, tags FROM turns'
  ' ORDER BY CASE source WHEN \"manual\" THEN 0 ELSE 1 END, ts DESC LIMIT 500'
).fetchall()
print(json.dumps([{'ts': r[0], 'source': r[1], 'summary': r[2] or '', 'tags': r[3] or ''} for r in rows]))
db.close()
" "$_mem_db" 2>/dev/null) || _mem_json='[]'

  # serialize gate_runs rows to JSON via python3
  _gates_json=$(python3 -c "
import sqlite3, json, sys
db = sqlite3.connect(sys.argv[1])
rows = db.execute(
  'SELECT ts, gate, outcome, coalesce(details,\"\") FROM gate_runs ORDER BY ts DESC LIMIT 500'
).fetchall()
print(json.dumps([{'ts': r[0], 'gate': r[1], 'outcome': r[2], 'details': r[3]} for r in rows]))
db.close()
" "$_audit_db" 2>/dev/null) || _gates_json='[]'

  _export_ts=$(python3 -c "import datetime; print(datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'))" 2>/dev/null) || _export_ts="unknown"

  say "export: writing $_export_output"

  # Write HTML to a temp file first, then move into place atomically.
  _export_tmp="${_export_output}.tmp.$$"

  cat > "$_export_tmp" << HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>clagentic-lite report</title>
<style>
  body { font-family: monospace; background: #1a1a1a; color: #d4d4d4; margin: 0; padding: 1rem 2rem; }
  h1 { font-size: 1.1rem; color: #9cdcfe; margin-bottom: 0.2rem; }
  .meta { font-size: 0.8rem; color: #6a9955; margin-bottom: 1.5rem; }
  .tabs { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
  .tab { padding: 0.3rem 1rem; cursor: pointer; background: #2d2d2d; border: 1px solid #444; color: #d4d4d4; font-family: monospace; font-size: 0.9rem; }
  .tab.active { background: #0e639c; border-color: #0e639c; color: #fff; }
  .panel { display: none; }
  .panel.active { display: block; }
  .controls { margin-bottom: 0.75rem; }
  input[type=text] { background: #2d2d2d; border: 1px solid #555; color: #d4d4d4; padding: 0.3rem 0.6rem; font-family: monospace; font-size: 0.85rem; width: 30rem; }
  .filter-btn { padding: 0.25rem 0.75rem; cursor: pointer; background: #2d2d2d; border: 1px solid #555; color: #d4d4d4; font-family: monospace; font-size: 0.85rem; margin-right: 0.3rem; }
  .filter-btn.active { border-color: #9cdcfe; color: #9cdcfe; }
  table { border-collapse: collapse; width: 100%; font-size: 0.82rem; }
  th { text-align: left; padding: 0.4rem 0.6rem; border-bottom: 1px solid #555; color: #9cdcfe; }
  td { padding: 0.35rem 0.6rem; border-bottom: 1px solid #2d2d2d; vertical-align: top; white-space: pre-wrap; word-break: break-word; }
  tr:hover td { background: #252526; }
  .src-manual { color: #4ec9b0; }
  .src-stop-hook { color: #6a9955; }
  .outcome-pass { color: #4ec9b0; }
  .outcome-block { color: #f44747; }
  .outcome-skip { color: #808080; }
  .outcome-warn { color: #dcdcaa; }
  .empty { color: #808080; padding: 1rem; }
</style>
</head>
<body>
<h1>clagentic-lite report</h1>
<div class="meta">repo: $_export_root &nbsp;|&nbsp; generated: $_export_ts</div>
<div class="tabs">
  <button class="tab active" onclick="switchTab('memory')">Memory</button>
  <button class="tab" onclick="switchTab('gates')">Gates</button>
</div>

<div id="panel-memory" class="panel active">
  <div class="controls">
    <input type="text" id="mem-search" placeholder="search memory..." oninput="filterMemory()">
  </div>
  <table id="mem-table">
    <thead><tr><th>ts</th><th>source</th><th>summary</th><th>tags</th></tr></thead>
    <tbody id="mem-body"></tbody>
  </table>
</div>

<div id="panel-gates" class="panel">
  <div class="controls">
    <button class="filter-btn active" onclick="filterGates('all',this)">all</button>
    <button class="filter-btn" onclick="filterGates('pass',this)">pass</button>
    <button class="filter-btn" onclick="filterGates('block',this)">block</button>
    <button class="filter-btn" onclick="filterGates('skip',this)">skip</button>
  </div>
  <table id="gates-table">
    <thead><tr><th>ts</th><th>gate</th><th>outcome</th><th>details</th></tr></thead>
    <tbody id="gates-body"></tbody>
  </table>
</div>

<script>
var MEM = $_mem_json;
var GATES = $_gates_json;
var _gatesFilter = 'all';

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function srcClass(s) {
  if (s === 'manual') return 'src-manual';
  if (s === 'stop-hook' || s === 'summarize-turn') return 'src-stop-hook';
  return '';
}

function outcomeClass(o) {
  if (o === 'pass')  return 'outcome-pass';
  if (o === 'block') return 'outcome-block';
  if (o === 'skip')  return 'outcome-skip';
  if (o === 'warn')  return 'outcome-warn';
  return '';
}

function renderMemory(rows) {
  var tb = document.getElementById('mem-body');
  if (!rows.length) { tb.innerHTML = '<tr><td colspan="4" class="empty">(no rows)</td></tr>'; return; }
  var html = '';
  for (var i = 0; i < rows.length; i++) {
    var r = rows[i];
    html += '<tr><td>' + esc(r.ts) + '</td>'
          + '<td class="' + srcClass(r.source) + '">' + esc(r.source) + '</td>'
          + '<td>' + esc(r.summary) + '</td>'
          + '<td>' + esc(r.tags) + '</td></tr>';
  }
  tb.innerHTML = html;
}

function filterMemory() {
  var q = document.getElementById('mem-search').value.toLowerCase();
  if (!q) { renderMemory(MEM); return; }
  var filtered = MEM.filter(function(r) {
    return (r.summary || '').toLowerCase().indexOf(q) !== -1
        || (r.tags    || '').toLowerCase().indexOf(q) !== -1
        || (r.source  || '').toLowerCase().indexOf(q) !== -1;
  });
  renderMemory(filtered);
}

function renderGates(rows) {
  var tb = document.getElementById('gates-body');
  if (!rows.length) { tb.innerHTML = '<tr><td colspan="4" class="empty">(no rows)</td></tr>'; return; }
  var html = '';
  for (var i = 0; i < rows.length; i++) {
    var r = rows[i];
    html += '<tr><td>' + esc(r.ts) + '</td>'
          + '<td>' + esc(r.gate) + '</td>'
          + '<td class="' + outcomeClass(r.outcome) + '">' + esc(r.outcome) + '</td>'
          + '<td>' + esc(r.details) + '</td></tr>';
  }
  tb.innerHTML = html;
}

function filterGates(outcome, btn) {
  _gatesFilter = outcome;
  var btns = document.querySelectorAll('.filter-btn');
  for (var i = 0; i < btns.length; i++) btns[i].classList.remove('active');
  if (btn) btn.classList.add('active');
  var rows = outcome === 'all' ? GATES : GATES.filter(function(r) { return r.outcome === outcome; });
  renderGates(rows);
}

function switchTab(name) {
  var tabs = document.querySelectorAll('.tab');
  var panels = document.querySelectorAll('.panel');
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
  for (var i = 0; i < panels.length; i++) panels[i].classList.remove('active');
  var idx = name === 'memory' ? 0 : 1;
  tabs[idx].classList.add('active');
  document.getElementById('panel-' + name).classList.add('active');
}

renderMemory(MEM);
renderGates(GATES);
</script>
</body>
</html>
HTMLEOF

  mv "$_export_tmp" "$_export_output"
  say "export complete: $_export_output"
  say "open with: open $_export_output  (macOS) or xdg-open $_export_output  (Linux)"
}

# ---------------------------------------------------------------- dispatch

case "${1:-}" in
  init)     shift; cmd_init "$@" ;;
  enroll)   shift; cmd_enroll "$@" ;;
  unenroll) shift; cmd_unenroll "$@" ;;
  list)     cmd_list ;;
  doctor)   cmd_doctor ;;
  update)   shift; cmd_update "$@" ;;
  recall)
    # recall <keywords...>  — search session memory for matching summaries.
    # Thin dispatch to scripts/memory.sh recall; honors CLAGENTIC_RECALL_LIMIT
    # and CLAGENTIC_RECALL_MAX_CHARS.
    shift
    exec "$SCRIPTS_DIR/memory.sh" recall "$@"
    ;;
  remember)
    # remember "<note>" [tags]  — store a manual memory entry.
    # Thin dispatch to scripts/memory.sh log-turn with source='manual'.
    # Does NOT add new plumbing; 'manual' source is already supported.
    shift
    if [ $# -eq 0 ]; then
      printf 'usage: clagentic-lite remember "<note>" [tags]\n' 1>&2
      exit 1
    fi
    _note="$1"; shift
    _tags="${*:-}"
    exec "$SCRIPTS_DIR/memory.sh" log-turn "$_note" "$_tags" "manual"
    ;;
  show)   shift; cmd_show "$@" ;;
  export) shift; cmd_export "$@" ;;
  gates)
    # gates <subcmd> [args...]  — proxy to the gate orchestrator.
    # gates.sh lives in CLAGENTIC_HOME/scripts/ and is not on PATH, so all
    # enrolled-repo command docs and CLAUDE.md files route through this
    # subcommand rather than referencing the bare scripts/ relative path.
    shift
    exec "$SCRIPTS_DIR/gates.sh" "$@"
    ;;
  "")
    printf 'usage: clagentic-lite <subcommand> [args]\n'
    printf 'subcommands: init, enroll, unenroll, list, doctor, update [--restamp], recall, remember, show, export, gates\n'
    exit 1
    ;;
  *)
    printf 'clagentic-lite: unknown subcommand: %s\n' "$1" 1>&2
    printf 'usage: clagentic-lite <subcommand> [args]\n'
    printf 'subcommands: init, enroll, unenroll, list, doctor, update [--restamp], recall, remember, show, export, gates\n'
    exit 1
    ;;
esac
